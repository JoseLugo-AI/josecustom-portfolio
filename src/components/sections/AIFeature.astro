---
interface Props {
  data: {
    heading?: string;
    title: string;
    description: string;
    icon?: string;
  };
}

const { data } = Astro.props;
---

<section class="py-20 md:py-28 bg-primary text-white">
  <div class="max-w-5xl mx-auto px-6 text-center">
    {data.heading && (
      <p class="text-accent text-sm font-body uppercase tracking-widest mb-4">{data.heading}</p>
    )}
    <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-accent/20 mb-8">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z" />
      </svg>
    </div>
    <h2 class="text-3xl md:text-4xl font-heading font-bold mb-6">{data.title}</h2>
    <p class="text-white/70 font-body text-lg leading-relaxed max-w-3xl mx-auto">{data.description}</p>
    <div class="mt-8 inline-flex items-center gap-2 text-sm text-accent font-body">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z" />
      </svg>
      AI-Ready Architecture by josecustom.ai
    </div>
  </div>
</section>
