---
interface Props {
  data: {
    heading?: string;
    services: { name: string; description: string }[];
  };
}

const { data } = Astro.props;
---

<section class="py-20 md:py-28 bg-secondary/30">
  <div class="max-w-5xl mx-auto px-6">
    {data.heading && (
      <h2 class="text-3xl md:text-4xl font-heading font-bold text-primary mb-12 text-center">{data.heading}</h2>
    )}
    <div class="space-y-0">
      {data.services.map((service, i) => (
        <div class="flex flex-col md:flex-row md:items-start gap-4 md:gap-8 py-8 border-b border-primary/10">
          <span class="text-sm font-body text-accent font-semibold shrink-0 w-8">0{i + 1}</span>
          <div>
            <h3 class="text-xl font-heading font-semibold text-primary mb-2">{service.name}</h3>
            <p class="text-text/60 font-body leading-relaxed">{service.description}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
