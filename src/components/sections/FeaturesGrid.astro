---
interface Props {
  data: {
    heading?: string;
    subheading?: string;
    features: { title: string; description: string; icon?: string }[];
  };
}

const { data } = Astro.props;
const icons: Record<string, string> = {
  star: 'M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z',
  check: 'M20 6L9 17l-5-5',
  clock: 'M12 2a10 10 0 100 20 10 10 0 000-20zm0 4v6l4 2',
  shield: 'M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z',
  zap: 'M13 2L3 14h9l-1 10 10-12h-9l1-10z',
  heart: 'M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z',
  users: 'M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2M9 11a4 4 0 100-8 4 4 0 000 8zM23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75',
  calendar: 'M19 4H5a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2V6a2 2 0 00-2-2zM16 2v4M8 2v4M3 10h18',
};
---

<section class="py-20 md:py-28 bg-bg">
  <div class="max-w-7xl mx-auto px-6">
    {data.heading && (
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-4xl font-heading font-bold text-primary mb-4">{data.heading}</h2>
        {data.subheading && <p class="text-text/60 max-w-2xl mx-auto font-body">{data.subheading}</p>}
      </div>
    )}
    <div class="grid md:grid-cols-2 lg:grid-cols-{data.features.length > 3 ? '4' : '3'} gap-8">
      {data.features.map(feature => (
        <div class="p-8 rounded-lg border border-primary/10 hover:border-accent/30 transition-colors">
          {feature.icon && icons[feature.icon] && (
            <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-accent mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d={icons[feature.icon]} />
            </svg>
          )}
          <h3 class="text-lg font-heading font-semibold text-primary mb-2">{feature.title}</h3>
          <p class="text-text/60 font-body text-sm leading-relaxed">{feature.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
