---
interface Props {
  name: string;
  address: string;
  phone: string;
  email: string;
}

const { name, address, phone, email } = Astro.props;
---

<footer class="bg-primary text-white py-16">
  <div class="max-w-7xl mx-auto px-6">
    <div class="grid md:grid-cols-3 gap-8 mb-12">
      <div>
        <h3 class="font-heading font-bold text-xl mb-4">{name}</h3>
        <p class="text-white/60 font-body text-sm">{address}</p>
      </div>
      <div>
        <h4 class="font-heading font-semibold text-sm uppercase tracking-wider mb-4 text-white/80">Contact</h4>
        <p class="text-white/60 font-body text-sm mb-1">{phone}</p>
        <p class="text-white/60 font-body text-sm">{email}</p>
      </div>
      <div>
        <h4 class="font-heading font-semibold text-sm uppercase tracking-wider mb-4 text-white/80">Hours</h4>
        <p class="text-white/60 font-body text-sm mb-1">Mon - Fri: 9am - 6pm</p>
        <p class="text-white/60 font-body text-sm">Sat - Sun: By appointment</p>
      </div>
    </div>
    <div class="border-t border-white/10 pt-8 flex flex-col md:flex-row justify-between items-center gap-4">
      <p class="text-white/40 font-body text-xs">&copy; 2026 {name}. All rights reserved.</p>
      <a href="https://josecustom.ai/websites" target="_blank" rel="noopener" class="text-white/40 hover:text-accent font-body text-xs transition-colors">
        Built by josecustom.ai
      </a>
    </div>
  </div>
</footer>
