---
interface Props {
  name: string;
  links: { label: string; href: string }[];
}

const { name, links } = Astro.props;
---

<nav class="bg-nav-bg sticky top-0 z-50 border-b border-primary/10">
  <div class="max-w-7xl mx-auto px-6 py-4 flex items-center justify-between">
    <a href="#" class="text-xl font-heading font-bold text-primary">{name}</a>
    <div class="hidden md:flex items-center gap-8">
      {links.map(link => (
        <a href={link.href} class="text-sm font-body text-text/70 hover:text-primary transition-colors">
          {link.label}
        </a>
      ))}
    </div>
    <button class="md:hidden text-primary" aria-label="Menu">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </div>
</nav>
