---
interface Props {
  name: string;
  links: { label: string; href: string }[];
}

const { name, links } = Astro.props;
---

<nav class="bg-nav-bg sticky top-0 z-50 border-b border-primary/10">
  <div class="max-w-7xl mx-auto px-6 py-6 flex flex-col items-center gap-4">
    <a href="#" class="text-2xl font-heading font-bold text-primary tracking-tight">{name}</a>
    <div class="hidden md:flex items-center gap-8">
      {links.map(link => (
        <a href={link.href} class="text-sm font-body text-text/70 hover:text-primary transition-colors uppercase tracking-wider">
          {link.label}
        </a>
      ))}
    </div>
  </div>
</nav>
