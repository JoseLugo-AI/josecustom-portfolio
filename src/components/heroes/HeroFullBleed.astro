---
interface Props {
  headline: string;
  subheadline: string;
  image: string;
  ctaText: string;
  ctaHref: string;
}

const { headline, subheadline, image, ctaText, ctaHref } = Astro.props;
---

<section class="relative min-h-[85vh] flex items-center justify-center overflow-hidden">
  <div class="absolute inset-0">
    <img src={image} alt="" class="w-full h-full object-cover" loading="eager" />
    <div class="absolute inset-0 bg-primary/60"></div>
  </div>
  <div class="relative z-10 max-w-4xl mx-auto px-6 text-center">
    <h1 class="text-4xl md:text-6xl lg:text-7xl font-heading font-bold text-white leading-tight mb-6">
      {headline}
    </h1>
    <p class="text-lg md:text-xl text-white/85 mb-8 max-w-2xl mx-auto font-body">
      {subheadline}
    </p>
    <a href={ctaHref} class="inline-block bg-accent text-white px-8 py-4 text-sm font-body font-semibold uppercase tracking-wider hover:opacity-90 transition-opacity">
      {ctaText}
    </a>
  </div>
</section>
