---
interface Props {
  headline: string;
  subheadline: string;
  image: string;
  ctaText: string;
  ctaHref: string;
}

const { headline, subheadline, image, ctaText, ctaHref } = Astro.props;
---

<section class="min-h-[80vh] grid md:grid-cols-2 items-center">
  <div class="px-8 md:px-16 py-16 md:py-24">
    <h1 class="text-4xl md:text-5xl lg:text-6xl font-heading font-bold text-primary leading-tight mb-6">
      {headline}
    </h1>
    <p class="text-lg text-text/70 mb-8 max-w-lg font-body">
      {subheadline}
    </p>
    <a href={ctaHref} class="inline-block bg-accent text-white px-8 py-4 text-sm font-body font-semibold uppercase tracking-wider hover:opacity-90 transition-opacity">
      {ctaText}
    </a>
  </div>
  <div class="h-full min-h-[400px]">
    <img src={image} alt="" class="w-full h-full object-cover" loading="eager" />
  </div>
</section>
