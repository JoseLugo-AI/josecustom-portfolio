---
interface Props {
  headline: string;
  subheadline: string;
  image: string;
  ctaText: string;
  ctaHref: string;
}

const { headline, subheadline, image, ctaText, ctaHref } = Astro.props;
---

<section class="relative min-h-[85vh] flex items-center overflow-hidden" style={`background: linear-gradient(135deg, var(--site-primary), var(--site-accent))`}>
  <div class="absolute right-0 top-0 w-1/2 h-full opacity-20 hidden md:block">
    <img src={image} alt="" class="w-full h-full object-cover" loading="eager" />
  </div>
  <div class="relative z-10 max-w-7xl mx-auto px-8 md:px-16 py-24">
    <h1 class="text-4xl md:text-6xl lg:text-7xl font-heading font-bold text-white leading-tight mb-6 max-w-3xl">
      {headline}
    </h1>
    <p class="text-lg md:text-xl text-white/80 mb-8 max-w-xl font-body">
      {subheadline}
    </p>
    <a href={ctaHref} class="inline-block bg-white text-primary px-8 py-4 text-sm font-body font-semibold uppercase tracking-wider hover:opacity-90 transition-opacity">
      {ctaText}
    </a>
  </div>
</section>
