---
/**
 * Southpaw Combat Club - College Park, Orlando
 * Movement Studios base + World Boxing design elements:
 * massive condensed hero type, gold accent (#D4A017), B&W action photos,
 * glass sticky nav, schedule timetable, full-bleed photo breaks
 */
import ScrollReveal from '../../components/ScrollReveal.tsx';
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Southpaw Combat Club | Show Up. Get Better.</title>
  <meta name="description" content="Brazilian Jiu-Jitsu, Muay Thai, and strength training in College Park, Orlando." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    html { scroll-behavior: smooth; }
    body {
      font-family: 'Inter', sans-serif;
      background: #0F0F0F;
      color: #E5E5E5;
      -webkit-font-smoothing: antialiased;
    }
    img { max-width: 100%; display: block; }
    a { color: inherit; text-decoration: none; }

    /* ── Sticky Glass Nav ── */
    .nav {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      z-index: 100;
      padding: 1rem 2.5rem;
      display: flex;
      align-items: center;
      justify-content: space-between;
      transition: background 0.4s, backdrop-filter 0.4s, box-shadow 0.4s;
    }
    .nav.scrolled {
      background: rgba(15, 15, 15, 0.75);
      backdrop-filter: blur(16px) saturate(1.4);
      -webkit-backdrop-filter: blur(16px) saturate(1.4);
      box-shadow: 0 1px 0 rgba(255,255,255,0.06);
    }
    .nav-links {
      display: flex;
      gap: 2rem;
      list-style: none;
    }
    .nav-links a {
      color: #fff;
      font-size: 0.65rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.14em;
      transition: color 0.3s;
    }
    .nav-links a:hover { color: #D4A017; }
    .nav-brand {
      font-family: 'Playfair Display', serif;
      font-size: 1rem;
      font-weight: 700;
      color: #fff;
      letter-spacing: 0.02em;
    }
    .nav-brand span { color: #D4A017; }

    /* ── Hero - MASSIVE condensed bold type like World Boxing ── */
    .hero {
      position: relative;
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      overflow: hidden;
      background: #0F0F0F;
    }
    .hero-bg {
      position: absolute;
      inset: 0;
      background: url('https://images.pexels.com/photos/4761792/pexels-photo-4761792.jpeg?auto=compress&cs=tinysrgb&w=1600') center/cover;
      filter: grayscale(100%) contrast(1.2);
    }
    .hero-bg::after {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(
        to bottom,
        rgba(15,15,15,0.3) 0%,
        rgba(15,15,15,0.5) 40%,
        rgba(15,15,15,0.85) 75%,
        #0F0F0F 100%
      );
    }
    .hero-content {
      position: relative;
      z-index: 1;
      text-align: center;
      padding: 0 2rem;
      max-width: 1000px;
    }
    .hero-label {
      font-size: 0.65rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.25em;
      color: #D4A017;
      margin-bottom: 1.5rem;
    }
    .hero-content h1 {
      font-family: 'Inter', sans-serif;
      font-size: clamp(4rem, 12vw, 9rem);
      font-weight: 900;
      color: #fff;
      line-height: 0.9;
      text-transform: uppercase;
      letter-spacing: -0.03em;
      margin-bottom: 2rem;
    }
    .hero-content h1 .accent { color: #D4A017; }
    .hero-sub {
      font-family: 'Playfair Display', serif;
      font-size: clamp(1rem, 2.5vw, 1.4rem);
      font-style: italic;
      color: rgba(255,255,255,0.6);
      margin-bottom: 2.5rem;
    }
    .hero-cta {
      display: inline-block;
      background: #D4A017;
      color: #0F0F0F;
      padding: 1rem 2.5rem;
      font-size: 0.7rem;
      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: 0.12em;
      transition: background 0.2s, transform 0.2s, box-shadow 0.2s;
    }
    .hero-cta:hover {
      background: #E8B82A;
      transform: translateY(-2px);
      box-shadow: 0 6px 24px rgba(212, 160, 23, 0.35);
    }

    /* ── Marquee ticker ── */
    .marquee {
      background: #6D28D9;
      padding: 0.6rem 0;
      overflow: hidden;
      white-space: nowrap;
    }
    .marquee-inner {
      display: inline-block;
      animation: scroll-left 25s linear infinite;
    }
    .marquee-text {
      font-size: 0.7rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: #fff;
    }
    .marquee-text span { margin: 0 2rem; opacity: 0.5; }
    @keyframes scroll-left {
      0% { transform: translateX(0); }
      100% { transform: translateX(-50%); }
    }

    /* ── Stats bar ── */
    .stats-bar {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      border-top: 1px solid rgba(255,255,255,0.08);
      border-bottom: 1px solid rgba(255,255,255,0.08);
    }
    .stat-item {
      text-align: center;
      padding: 2.5rem 1rem;
      border-right: 1px solid rgba(255,255,255,0.08);
    }
    .stat-item:last-child { border-right: none; }
    .stat-number {
      font-size: clamp(2rem, 5vw, 3rem);
      font-weight: 900;
      color: #D4A017;
      line-height: 1;
      margin-bottom: 0.4rem;
    }
    .stat-label {
      font-size: 0.65rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.12em;
      color: #888;
    }

    /* ── Content sections ── */
    .section-dark {
      background: #0F0F0F;
      padding: 6rem 2rem;
    }
    .section-inner {
      max-width: 700px;
      margin: 0 auto;
    }
    .section-label {
      font-size: 0.6rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.2em;
      color: #D4A017;
      margin-bottom: 1rem;
    }
    .section-title {
      font-family: 'Inter', sans-serif;
      font-size: clamp(1.8rem, 4vw, 2.8rem);
      font-weight: 900;
      color: #fff;
      text-transform: uppercase;
      letter-spacing: -0.02em;
      line-height: 1.05;
      margin-bottom: 1.5rem;
    }
    .section-text {
      font-size: 0.9rem;
      color: #999;
      line-height: 1.8;
      margin-bottom: 1.5rem;
    }
    .section-cta {
      display: inline-block;
      background: #6D28D9;
      color: #fff;
      padding: 0.8rem 2rem;
      font-size: 0.65rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      transition: background 0.2s, transform 0.2s, box-shadow 0.2s;
    }
    .section-cta:hover {
      background: #5B21B6;
      transform: translateY(-2px);
      box-shadow: 0 4px 16px rgba(109, 40, 217, 0.35);
    }

    /* ── Full-bleed B&W action photo break ── */
    .photo-break {
      position: relative;
      width: 100%;
      height: 50vh;
      min-height: 350px;
      overflow: hidden;
    }
    .photo-break img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      filter: grayscale(100%) contrast(1.15);
    }
    .photo-break-overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(
        to bottom,
        rgba(15,15,15,0.4) 0%,
        transparent 30%,
        transparent 70%,
        rgba(15,15,15,0.6) 100%
      );
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .photo-break-text {
      font-family: 'Inter', sans-serif;
      font-size: clamp(2rem, 6vw, 5rem);
      font-weight: 900;
      color: #fff;
      text-transform: uppercase;
      letter-spacing: -0.02em;
      text-shadow: 0 2px 40px rgba(0,0,0,0.6);
    }

    /* ── Programs grid ── */
    .programs-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 1px;
      background: rgba(255,255,255,0.06);
      max-width: 1100px;
      margin: 0 auto;
    }
    .program-card {
      background: #0F0F0F;
      padding: 2.5rem 2rem;
      transition: background 0.3s;
    }
    .program-card:hover { background: #141414; }
    .program-icon {
      font-size: 1.8rem;
      margin-bottom: 1rem;
    }
    .program-name {
      font-size: 0.85rem;
      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      color: #fff;
      margin-bottom: 0.5rem;
    }
    .program-desc {
      font-size: 0.8rem;
      color: #777;
      line-height: 1.7;
    }
    .program-tag {
      display: inline-block;
      margin-top: 1rem;
      font-size: 0.55rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.12em;
      color: #D4A017;
      border: 1px solid rgba(212,160,23,0.3);
      padding: 0.3rem 0.7rem;
    }

    /* ── Schedule timetable ── */
    .schedule-section {
      background: #0A0A0A;
      padding: 6rem 2rem;
    }
    .schedule-header {
      text-align: center;
      margin-bottom: 3rem;
    }
    .schedule-table {
      max-width: 900px;
      margin: 0 auto;
      width: 100%;
      border-collapse: collapse;
    }
    .schedule-table thead th {
      font-size: 0.6rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.15em;
      color: #D4A017;
      padding: 1rem 0.5rem;
      text-align: center;
      border-bottom: 1px solid rgba(255,255,255,0.1);
    }
    .schedule-table tbody td {
      font-size: 0.75rem;
      color: #ccc;
      padding: 0.9rem 0.5rem;
      text-align: center;
      border-bottom: 1px solid rgba(255,255,255,0.04);
    }
    .schedule-table tbody tr:hover td {
      background: rgba(109, 40, 217, 0.06);
    }
    .schedule-table .time-col {
      font-weight: 700;
      color: #D4A017;
      text-align: left;
      font-size: 0.7rem;
      white-space: nowrap;
    }
    .class-bjj { color: #C084FC; }
    .class-mt { color: #F59E0B; }
    .class-sc { color: #34D399; }
    .class-open { color: #888; font-style: italic; }
    .schedule-legend {
      display: flex;
      justify-content: center;
      gap: 2rem;
      margin-top: 2rem;
      flex-wrap: wrap;
    }
    .legend-item {
      display: flex;
      align-items: center;
      gap: 0.4rem;
      font-size: 0.65rem;
      font-weight: 600;
      color: #888;
    }
    .legend-dot {
      width: 8px;
      height: 8px;
      border-radius: 50%;
    }
    .legend-dot.bjj { background: #C084FC; }
    .legend-dot.mt { background: #F59E0B; }
    .legend-dot.sc { background: #34D399; }

    /* ── Founder quote section ── */
    .founder-section {
      padding: 6rem 2rem;
      background: #0F0F0F;
      border-top: 1px solid rgba(255,255,255,0.06);
    }
    .founder-inner {
      max-width: 700px;
      margin: 0 auto;
    }
    .founder-quote {
      font-family: 'Playfair Display', serif;
      font-size: clamp(1.3rem, 3vw, 2rem);
      font-style: italic;
      color: #fff;
      line-height: 1.5;
      margin-bottom: 2rem;
    }
    .founder-quote::before {
      content: '\201C';
      display: block;
      font-size: 4rem;
      color: #D4A017;
      line-height: 0.5;
      margin-bottom: 1rem;
    }
    .founder-name {
      font-size: 0.85rem;
      font-weight: 800;
      color: #D4A017;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      border-left: 3px solid #6D28D9;
      padding-left: 1rem;
      margin-bottom: 0.25rem;
    }
    .founder-role {
      font-size: 0.7rem;
      color: #666;
      padding-left: 1rem;
      border-left: 3px solid transparent;
    }

    /* ── Gradient CTA ── */
    .gradient-cta {
      background: linear-gradient(135deg, #6D28D9 0%, #4C1D95 50%, #1E1B4B 100%);
      padding: 6rem 2rem;
      position: relative;
      overflow: hidden;
    }
    .gradient-cta::before {
      content: '';
      position: absolute;
      top: -50%;
      right: -20%;
      width: 500px;
      height: 500px;
      background: radial-gradient(circle, rgba(212,160,23,0.15) 0%, transparent 70%);
      pointer-events: none;
    }
    .gradient-cta-inner {
      max-width: 700px;
      margin: 0 auto;
      position: relative;
      z-index: 1;
    }
    .gradient-cta h2 {
      font-family: 'Inter', sans-serif;
      font-size: clamp(1.4rem, 3vw, 2rem);
      font-weight: 800;
      color: #fff;
      line-height: 1.4;
      margin-bottom: 2rem;
    }
    .gradient-cta-btn {
      display: inline-block;
      background: #D4A017;
      color: #0F0F0F;
      padding: 1rem 2.5rem;
      font-size: 0.7rem;
      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      transition: background 0.2s, transform 0.2s, box-shadow 0.2s;
    }
    .gradient-cta-btn:hover {
      background: #E8B82A;
      transform: translateY(-2px);
      box-shadow: 0 6px 24px rgba(212, 160, 23, 0.3);
    }

    /* ── AI section ── */
    .ai-section {
      padding: 4rem 2rem;
      text-align: center;
      max-width: 600px;
      margin: 0 auto;
    }
    .ai-section h3 {
      font-size: 0.85rem;
      font-weight: 800;
      color: #fff;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      margin-bottom: 0.75rem;
    }
    .ai-section p {
      font-size: 0.8rem;
      color: #666;
      line-height: 1.8;
    }
    .ai-badge {
      margin-top: 1.2rem;
      font-size: 0.55rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.14em;
      color: #D4A017;
    }

    /* ── Footer - dark with gold social icons like World Boxing ── */
    .footer {
      background: #080808;
      color: #555;
      padding: 4rem 2rem 2rem;
      border-top: 1px solid rgba(255,255,255,0.06);
    }
    .footer-inner {
      max-width: 900px;
      margin: 0 auto;
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      gap: 2rem;
    }
    .footer-brand {
      font-family: 'Inter', sans-serif;
      font-size: 1rem;
      font-weight: 900;
      text-transform: uppercase;
      letter-spacing: 0.04em;
      color: #fff;
      margin-bottom: 0.5rem;
    }
    .footer-tagline {
      font-size: 0.65rem;
      color: #444;
      font-style: italic;
    }
    .footer-social {
      display: flex;
      gap: 1rem;
      margin-top: 1rem;
    }
    .footer-social a {
      color: #D4A017;
      font-size: 0.65rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      transition: color 0.3s;
    }
    .footer-social a:hover { color: #E8B82A; }
    .footer-info {
      font-size: 0.7rem;
      color: #444;
      text-align: right;
      line-height: 1.8;
    }
    .footer-info a {
      color: #6D28D9;
      transition: color 0.3s;
    }
    .footer-info a:hover {
      color: #C084FC;
      text-decoration: underline;
    }
    .footer-bottom {
      max-width: 900px;
      margin: 2rem auto 0;
      padding-top: 1.5rem;
      border-top: 1px solid rgba(255,255,255,0.04);
      text-align: center;
      font-size: 0.6rem;
      color: #333;
    }

    .cta-badge {
      position: fixed;
      bottom: 1rem;
      right: 1rem;
      z-index: 50;
      background: rgba(15,15,15,0.9);
      border: 1px solid #333;
      color: #fff;
      padding: 0.5rem 1rem;
      border-radius: 999px;
      font-size: 0.7rem;
      backdrop-filter: blur(8px);
      transition: all 0.2s;
    }
    .cta-badge:hover { background: #D4A017; border-color: #D4A017; color: #0F0F0F; }

    /* ── Responsive ── */
    @media (max-width: 768px) {
      .nav { padding: 0.8rem 1.2rem; }
      .nav-links { gap: 1rem; }
      .nav-links a { font-size: 0.55rem; }
      .hero-content { padding: 0 1.2rem; }
      .stats-bar { grid-template-columns: 1fr; }
      .stat-item { border-right: none; border-bottom: 1px solid rgba(255,255,255,0.08); padding: 1.5rem; }
      .stat-item:last-child { border-bottom: none; }
      .programs-grid { grid-template-columns: 1fr; }
      .schedule-table { font-size: 0.65rem; }
      .schedule-table thead th { font-size: 0.5rem; padding: 0.6rem 0.3rem; }
      .schedule-table tbody td { padding: 0.6rem 0.3rem; font-size: 0.65rem; }
      .footer-inner { flex-direction: column; text-align: center; align-items: center; }
      .footer-info { text-align: center; }
      .photo-break { height: 35vh; min-height: 250px; }
    }
  </style>
</head>
<body>

  <!-- Sticky Glass Nav -->
  <nav class="nav" id="mainNav">
    <div class="nav-brand">SOUTHPAW<span>.</span></div>
    <ul class="nav-links">
      <li><a href="#programs">Programs</a></li>
      <li><a href="#schedule">Schedule</a></li>
      <li><a href="#about">About</a></li>
      <li><a href="#contact">Contact</a></li>
    </ul>
  </nav>

  <!-- Hero - massive condensed bold type -->
  <section class="hero">
    <div class="hero-bg"></div>
    <div class="hero-content">
      <div class="hero-label">College Park, Orlando -- Est. 2020</div>
      <h1>SHOW<br />UP<span class="accent">.</span> GET<br />BETTER<span class="accent">.</span></h1>
      <div class="hero-sub">Brazilian Jiu-Jitsu, Muay Thai, Strength & Conditioning</div>
      <a href="#contact" class="hero-cta">Start Your Free Week</a>
    </div>
  </section>

  <!-- Marquee -->
  <div class="marquee">
    <div class="marquee-inner">
      <span class="marquee-text">Brazilian Jiu-Jitsu <span>&bull;</span> Muay Thai <span>&bull;</span> Strength & Conditioning <span>&bull;</span> No Contracts <span>&bull;</span> First Week Free <span>&bull;</span> Brazilian Jiu-Jitsu <span>&bull;</span> Muay Thai <span>&bull;</span> Strength & Conditioning <span>&bull;</span> No Contracts <span>&bull;</span> First Week Free <span>&bull;</span></span>
    </div>
  </div>

  <!-- Stats bar -->
  <ScrollReveal client:load>
    <div class="stats-bar">
      <div class="stat-item">
        <div class="stat-number">150+</div>
        <div class="stat-label">Active Members</div>
      </div>
      <div class="stat-item">
        <div class="stat-number">2020</div>
        <div class="stat-label">Established</div>
      </div>
      <div class="stat-item">
        <div class="stat-number">3</div>
        <div class="stat-label">Combat Disciplines</div>
      </div>
    </div>
  </ScrollReveal>

  <!-- Who We Are -->
  <ScrollReveal client:load>
    <section class="section-dark" id="about">
      <div class="section-inner">
        <div class="section-label">Who We Are</div>
        <h2 class="section-title">Built on discipline.<br />Run on respect.</h2>
        <p class="section-text">Southpaw opened in College Park in 2020 with 12 members and a rented warehouse. Coach Andre Watts -- former Army combatives instructor, brown belt in BJJ -- built the gym on one principle: train hard, leave your ego at the door. We're at 150 members now across all programs.</p>
        <a href="#contact" class="section-cta">About Us</a>
      </div>
    </section>
  </ScrollReveal>

  <!-- Full-bleed B&W action photo break -->
  <ScrollReveal client:load>
    <div class="photo-break">
      <img src="https://images.pexels.com/photos/6295903/pexels-photo-6295903.jpeg?auto=compress&cs=tinysrgb&w=1600" alt="Boxing gym training" loading="lazy" />
      <div class="photo-break-overlay">
        <div class="photo-break-text">Train Hard</div>
      </div>
    </div>
  </ScrollReveal>

  <!-- Programs -->
  <ScrollReveal client:load>
    <section class="section-dark" id="programs">
      <div style="max-width: 1100px; margin: 0 auto;">
        <div style="text-align: center; margin-bottom: 3rem;">
          <div class="section-label">Our Programs</div>
          <h2 class="section-title">Find your fight</h2>
        </div>
        <div class="programs-grid">
          <div class="program-card">
            <div class="program-icon">&#129354;</div>
            <div class="program-name">Brazilian Jiu-Jitsu</div>
            <p class="program-desc">Gi and no-gi classes for all levels. From fundamentals to advanced competition prep. Learn submissions, sweeps, and positional control.</p>
            <div class="program-tag">All Levels</div>
          </div>
          <div class="program-card">
            <div class="program-icon">&#129354;</div>
            <div class="program-name">Muay Thai</div>
            <p class="program-desc">The art of eight limbs. Develop devastating strikes, clinch work, and fight IQ through structured pad rounds and sparring.</p>
            <div class="program-tag">Striking</div>
          </div>
          <div class="program-card">
            <div class="program-icon">&#127947;</div>
            <div class="program-name">Strength & Conditioning</div>
            <p class="program-desc">Sport-specific programming designed for combat athletes. Build explosive power, endurance, and injury resilience.</p>
            <div class="program-tag">Performance</div>
          </div>
          <div class="program-card">
            <div class="program-icon">&#127942;</div>
            <div class="program-name">Competition Team</div>
