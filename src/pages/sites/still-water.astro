---
/**
 * Still Water Tattoo - Ivanhoe Village, Orlando
 * Matched to: nature-slam / Véloce Figma template (white/cream bg, bold condensed black uppercase,
 * asymmetric product layouts, yellow nav accent, minimal product-forward)
 */
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Still Water Tattoo | Permanent Work. No Rush.</title>
  <meta name="description" content="Custom tattoo design in Ivanhoe Village, Orlando. Every piece starts with a conversation." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Roboto+Condensed:wght@400;700;800;900&family=Roboto:wght@400;500&display=swap" rel="stylesheet" />
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    html { scroll-behavior: smooth; }
    body {
      font-family: 'Roboto', sans-serif;
      background: #FAFAFA;
      color: #1A1A1A;
      -webkit-font-smoothing: antialiased;
    }
    img { max-width: 100%; display: block; }
    a { color: inherit; text-decoration: none; }

    /* Nav - minimal like Véloce, yellow underline */
    .nav {
      padding: 1.5rem 2rem;
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      border-bottom: 3px solid #D4A017;
    }
    .nav-brand {
      font-family: 'Roboto Condensed', sans-serif;
      font-size: 1.1rem;
      font-weight: 900;
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }
    .nav-links { display: flex; flex-direction: column; align-items: flex-end; gap: 0.25rem; }
    .nav-links a {
      font-family: 'Roboto Condensed', sans-serif;
      font-size: 0.7rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: #1A1A1A;
      transition: color 0.2s;
    }
    .nav-links a:hover { color: #D4A017; }

    /* Hero - bold condensed type, left-aligned like Véloce */
    .hero {
      padding: 4rem 2rem 2rem;
      max-width: 900px;
    }
    .hero h1 {
      font-family: 'Roboto Condensed', sans-serif;
      font-size: clamp(1.8rem, 4vw, 2.5rem);
      font-weight: 900;
      text-transform: uppercase;
      letter-spacing: -0.02em;
      line-height: 1.15;
      margin-bottom: 2rem;
    }
    .hero-cta {
      display: inline-block;
      background: #1A1A1A;
      color: #fff;
      padding: 0.7rem 1.5rem;
      font-family: 'Roboto Condensed', sans-serif;
      font-size: 0.7rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      transition: opacity 0.2s;
    }
    .hero-cta:hover { opacity: 0.8; }

    /* Large manifesto text - like Véloce's big description */
    .manifesto {
      padding: 3rem 2rem 4rem;
      max-width: 900px;
    }
    .manifesto p {
      font-family: 'Roboto Condensed', sans-serif;
      font-size: clamp(1.5rem, 4vw, 2.2rem);
      font-weight: 900;
      text-transform: uppercase;
      letter-spacing: -0.01em;
      line-height: 1.2;
      color: #1A1A1A;
    }
    .manifesto .cta-link {
      display: inline-block;
      margin-top: 1.5rem;
      font-family: 'Roboto Condensed', sans-serif;
      font-size: 0.65rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      border-bottom: 2px solid #1A1A1A;
      padding-bottom: 2px;
    }

    /* Product/Service cards - asymmetric like Véloce product showcase */
    .showcase { padding: 0 2rem 4rem; }
    .showcase-card {
      max-width: 900px;
      margin-bottom: 3rem;
    }
    .showcase-card-badge {
      display: inline-block;
      background: #D4A017;
      color: #000;
      padding: 0.25rem 0.75rem;
      font-family: 'Roboto Condensed', sans-serif;
      font-size: 0.6rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      margin-bottom: 1rem;
    }
    .showcase-card img {
      width: 100%;
      max-width: 500px;
      height: 350px;
      object-fit: cover;
      margin-bottom: 1rem;
    }
    .showcase-card-title {
      font-family: 'Roboto Condensed', sans-serif;
      font-size: 1.8rem;
      font-weight: 900;
      text-transform: uppercase;
      letter-spacing: -0.02em;
      font-style: italic;
      margin-bottom: 0.5rem;
    }
    .showcase-card-desc {
      font-size: 0.7rem;
      font-weight: 500;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: #666;
      max-width: 400px;
      line-height: 1.5;
    }
    .showcase-card .cta-link {
      display: inline-block;
      margin-top: 1rem;
      font-family: 'Roboto Condensed', sans-serif;
      font-size: 0.6rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      border-bottom: 1px solid #1A1A1A;
      padding-bottom: 2px;
    }
    /* Alternate: image right */
    .showcase-card.right { display: flex; flex-direction: row-reverse; gap: 2rem; align-items: flex-start; }
    .showcase-card.right img { margin-bottom: 0; }

    /* Big stacked type section - like Véloce's product name stacking */
    .stacked-type {
      background: #1A1A1A;
      color: #FAFAFA;
      padding: 4rem 2rem;
    }
    .stacked-type-inner { max-width: 900px; margin: 0 auto; }
    .stacked-type h2 {
      font-family: 'Roboto Condensed', sans-serif;
      font-size: clamp(3rem, 10vw, 6rem);
      font-weight: 900;
      text-transform: uppercase;
      line-height: 0.95;
      letter-spacing: -0.03em;
      margin-bottom: 2rem;
    }
    .stacked-type p {
      font-size: 0.85rem;
      color: #aaa;
      line-height: 1.7;
      max-width: 500px;
      margin-bottom: 1.5rem;
    }

    /* AI Feature */
    .ai-section {
      background: #FAFAFA;
      padding: 4rem 2rem;
      text-align: center;
      border-top: 3px solid #D4A017;
    }
    .ai-section h2 {
      font-family: 'Roboto Condensed', sans-serif;
      font-size: 1.5rem;
      font-weight: 900;
      text-transform: uppercase;
      margin-bottom: 1rem;
    }
    .ai-section p {
      max-width: 480px;
      margin: 0 auto;
      font-size: 0.85rem;
      color: #666;
      line-height: 1.7;
    }
    .ai-badge {
      margin-top: 1.5rem;
      font-size: 0.55rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.12em;
      color: #ccc;
    }

    /* Footer - like Véloce's dark footer */
    .footer {
      background: #1A1A1A;
      color: #FAFAFA;
      padding: 3rem 2rem;
    }
    .footer-inner {
      max-width: 900px;
      margin: 0 auto;
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
    }
    .footer-brand {
      font-family: 'Roboto Condensed', sans-serif;
      font-size: 1.5rem;
      font-weight: 900;
      text-transform: uppercase;
    }
    .footer-col p {
      font-size: 0.75rem;
      color: #888;
      line-height: 1.8;
    }
    .footer-col a { color: #D4A017; }
    .footer-col a:hover { text-decoration: underline; }
    .footer-bottom {
      max-width: 900px;
      margin: 2rem auto 0;
      padding-top: 1.5rem;
      border-top: 1px solid #333;
      font-size: 0.6rem;
      color: #555;
      text-align: center;
    }

    .cta-badge {
      position: fixed;
      bottom: 1rem;
      right: 1rem;
      z-index: 50;
      background: rgba(26,26,26,0.9);
      border: 1px solid #333;
      color: #FAFAFA;
      padding: 0.5rem 1rem;
      border-radius: 999px;
      font-size: 0.7rem;
      backdrop-filter: blur(8px);
      transition: all 0.2s;
    }
    .cta-badge:hover { background: #D4A017; color: #000; border-color: #D4A017; }

    @media (max-width: 768px) {
      .showcase-card.right { flex-direction: column; }
      .showcase-card.right img { margin-bottom: 1rem; }
      .footer-inner { flex-direction: column; gap: 1.5rem; }
      .nav-links { display: none; }
    }
  </style>
</head>
<body>

  <nav class="nav">
    <div class="nav-brand">Still Water</div>
    <div class="nav-links">
      <a href="#work">Work</a>
      <a href="#about">About</a>
      <a href="#contact">Contact</a>
    </div>
  </nav>

  <section class="hero">
    <h1>The only custom tattoo studio that takes as good as it makes you feel.</h1>
    <a href="#contact" class="hero-cta">Book a Consultation</a>
  </section>

  <section class="manifesto">
    <p>Still Water is the custom tattoo studio for intentional work. Every piece starts with a conversation, designed for your body and your story, without compromising the craft of permanent art.</p>
    <a href="#about" class="cta-link">About Us</a>
  </section>

  <section id="work" class="showcase">
    <div class="showcase-card">
      <div class="showcase-card-badge">Custom</div>
      <img src="https://images.unsplash.com/photo-1590246814883-57c511e76228?w=800&q=80" alt="Fine line botanical tattoo" />
      <div class="showcase-card-title">Fine Line</div>
      <div class="showcase-card-desc">Delicate botanical and geometric work. Precision placement for pieces that age beautifully.</div>
      <a href="#contact" class="cta-link">Book This Style</a>
    </div>

    <div class="showcase-card right">
      <img src="https://images.unsplash.com/photo-1562962230-16e4623d36e6?w=800&q=80" alt="Black and grey portrait" />
      <div>
        <div class="showcase-card-title">Blackwork</div>
        <div class="showcase-card-desc">Bold black and grey work. Portraits, traditional, and custom compositions built for impact.</div>
        <a href="#contact" class="cta-link">Book This Style</a>
      </div>
    </div>

    <div class="showcase-card">
      <img src="https://images.unsplash.com/photo-1598371839696-5c5bb1fed6e2?w=800&q=80" alt="Geometric sleeve" />
      <div class="showcase-card-title">Cover-Ups</div>
      <div class="showcase-card-desc">Turning old or unwanted tattoos into something you're proud of. We design around what's there.</div>
      <a href="#contact" class="cta-link">Book This Style</a>
    </div>
  </section>

  <section id="about" class="stacked-type">
    <div class="stacked-type-inner">
      <h2>Fine Line<br />Blackwork<br />Custom<br />Ivanhoe Village</h2>
      <p>Still Water is a two-artist studio on Orange Avenue in Ivanhoe Village. Artists Reina Torres and James Oku focus on custom work only. We book 3-4 weeks out because we don't stack clients.</p>
      <p>The studio doubles as a small gallery showing original work from local artists on a rotating basis.</p>
    </div>
  </section>

  <section class="ai-section">
    <h2>Visual Reference Builder</h2>
    <p>Describe your idea in words, and our tool generates a mood board with style references, color palettes, and composition options for your artist to work from.</p>
    <div class="ai-badge">AI-Ready Architecture by josecustom.ai</div>
  </section>

  <footer id="contact" class="footer">
    <div class="footer-inner">
      <div class="footer-brand">Still Water</div>
      <div class="footer-col">
        <p><a href="mailto:book@stillwatertattoo.com">book@stillwatertattoo.com</a><br />
        (407) 555-8104<br />
        1827 N Orange Ave<br />
        Orlando, FL 32804</p>
      </div>
    </div>
    <div class="footer-bottom">
      &copy; 2026 Still Water Tattoo &middot; <a href="https://josecustom.ai/websites" target="_blank" rel="noopener" style="color:#D4A017;">Built by josecustom.ai</a>
    </div>
  </footer>

  <a href="https://josecustom.ai/websites" target="_blank" rel="noopener" class="cta-badge">Demo site by josecustom.ai</a>

</body>
</html>
