---
/**
 * Still Water Tattoo - Ivanhoe Village, Orlando
 * Rebuilt: Veloce template structure + mommyimsorry.com editorial tattoo aesthetic
 * Dark/moody hero, portfolio gallery grid, artist profile cards, B&W contrast with gold accent
 */
import ScrollReveal from '../../components/ScrollReveal.tsx';
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Still Water Tattoo | Permanent Work. No Rush.</title>
  <meta name="description" content="Custom tattoo design in Ivanhoe Village, Orlando. Every piece starts with a conversation." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Roboto+Condensed:wght@400;700;800;900&family=Roboto:wght@400;500&display=swap" rel="stylesheet" />
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    html { scroll-behavior: smooth; }
    body {
      font-family: 'Roboto', sans-serif;
      background: #0A0A0A;
      color: #FAFAFA;
      -webkit-font-smoothing: antialiased;
    }
    img { max-width: 100%; display: block; }
    a { color: inherit; text-decoration: none; }

    /* ── Sticky Nav - glass on scroll ── */
    .nav {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      z-index: 100;
      padding: 1.25rem 2.5rem;
      display: flex;
      align-items: center;
      justify-content: space-between;
      transition: background 0.4s ease, backdrop-filter 0.4s ease, box-shadow 0.4s ease;
    }
    .nav.scrolled {
      background: rgba(10, 10, 10, 0.85);
      backdrop-filter: blur(16px);
      -webkit-backdrop-filter: blur(16px);
      box-shadow: 0 1px 0 rgba(212, 160, 23, 0.15);
    }
    .nav-brand {
      font-family: 'Roboto Condensed', sans-serif;
      font-size: 1rem;
      font-weight: 900;
      text-transform: uppercase;
      letter-spacing: 0.15em;
      color: #FAFAFA;
    }
    .nav-brand span { color: #D4A017; }
    .nav-links { display: flex; gap: 2rem; align-items: center; }
    .nav-links a {
      font-family: 'Roboto Condensed', sans-serif;
      font-size: 0.65rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.15em;
      color: #888;
      transition: color 0.3s ease;
    }
    .nav-links a:hover { color: #D4A017; }
    .nav-links .nav-cta {
      color: #0A0A0A;
      background: #D4A017;
      padding: 0.5rem 1.25rem;
      font-size: 0.6rem;
      letter-spacing: 0.12em;
      transition: background 0.3s ease, transform 0.2s ease;
    }
    .nav-links .nav-cta:hover {
      background: #e6b422;
      transform: translateY(-1px);
    }

    /* ── Hero - full-bleed editorial dark ── */
    .hero {
      position: relative;
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      text-align: center;
      overflow: hidden;
      background: #0A0A0A;
    }
    .hero-bg {
      position: absolute;
      inset: 0;
      z-index: 0;
    }
    .hero-bg img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      filter: grayscale(100%) brightness(0.25) contrast(1.2);
    }
    .hero-overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(180deg, rgba(10,10,10,0.6) 0%, rgba(10,10,10,0.85) 60%, #0A0A0A 100%);
      z-index: 1;
    }
    .hero-content {
      position: relative;
      z-index: 2;
      max-width: 800px;
      padding: 0 2rem;
    }
    .hero-label {
      font-family: 'Roboto Condensed', sans-serif;
      font-size: 0.6rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.3em;
      color: #D4A017;
      margin-bottom: 2rem;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 1rem;
    }
    .hero-label::before,
    .hero-label::after {
      content: '';
      width: 40px;
      height: 1px;
      background: #D4A017;
    }
    .hero h1 {
      font-family: 'Roboto Condensed', sans-serif;
      font-size: clamp(3rem, 8vw, 6.5rem);
      font-weight: 900;
      text-transform: uppercase;
      letter-spacing: -0.03em;
      line-height: 0.92;
      margin-bottom: 1.5rem;
      color: #FAFAFA;
    }
    .hero h1 em {
      font-style: italic;
      color: #D4A017;
      display: block;
    }
    .hero-sub {
      font-size: 0.85rem;
      color: #888;
      line-height: 1.8;
      max-width: 480px;
      margin: 0 auto 2.5rem;
      font-weight: 400;
    }
    .hero-cta {
      display: inline-block;
      background: #D4A017;
      color: #0A0A0A;
      padding: 0.85rem 2.5rem;
      font-family: 'Roboto Condensed', sans-serif;
      font-size: 0.7rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.12em;
      transition: background 0.3s ease, transform 0.2s ease, box-shadow 0.3s ease;
    }
    .hero-cta:hover {
      background: #e6b422;
      transform: translateY(-2px);
      box-shadow: 0 8px 32px rgba(212, 160, 23, 0.3);
    }
    .hero-scroll {
      position: absolute;
      bottom: 2.5rem;
      left: 50%;
      transform: translateX(-50%);
      z-index: 2;
      font-size: 0.55rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.2em;
      color: #555;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.5rem;
    }
    .hero-scroll span {
      width: 1px;
      height: 40px;
      background: linear-gradient(to bottom, #D4A017, transparent);
      animation: scrollPulse 2s ease-in-out infinite;
    }
    @keyframes scrollPulse {
      0%, 100% { opacity: 0.3; }
      50% { opacity: 1; }
    }

    /* ── Section utilities ── */
    .section-label {
      font-family: 'Roboto Condensed', sans-serif;
      font-size: 0.55rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.3em;
      color: #D4A017;
      margin-bottom: 1rem;
    }
    .section-heading {
      font-family: 'Roboto Condensed', sans-serif;
      font-size: clamp(2rem, 5vw, 3.5rem);
      font-weight: 900;
      text-transform: uppercase;
      letter-spacing: -0.02em;
      line-height: 1;
      color: #FAFAFA;
    }
    .section-divider {
      width: 60px;
      height: 2px;
      background: #D4A017;
      margin: 1.5rem 0;
    }

    /* ── Portfolio Gallery Grid ── */
    .portfolio {
      padding: 6rem 2rem;
      background: #0A0A0A;
    }
    .portfolio-header {
      text-align: center;
      max-width: 600px;
      margin: 0 auto 3.5rem;
    }
    .portfolio-header p {
      font-size: 0.85rem;
      color: #666;
      line-height: 1.7;
      margin-top: 1rem;
    }
    .portfolio-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 4px;
      max-width: 1000px;
      margin: 0 auto;
    }
    .portfolio-item {
      position: relative;
      aspect-ratio: 1;
      overflow: hidden;
      cursor: pointer;
    }
    .portfolio-item img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      filter: grayscale(80%);
      transition: filter 0.5s ease, transform 0.5s ease;
    }
    .portfolio-item:hover img {
      filter: grayscale(0%);
      transform: scale(1.08);
    }
    .portfolio-overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(180deg, transparent 40%, rgba(10,10,10,0.9) 100%);
      opacity: 0;
      transition: opacity 0.4s ease;
      display: flex;
      align-items: flex-end;
      padding: 1.25rem;
    }
    .portfolio-item:hover .portfolio-overlay {
      opacity: 1;
    }
    .portfolio-overlay span {
      font-family: 'Roboto Condensed', sans-serif;
      font-size: 0.7rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: #D4A017;
    }

    /* ── Artist Profile Cards ── */
    .artists {
      padding: 6rem 2rem;
      background: #111;
    }
    .artists-header {
      text-align: center;
      max-width: 600px;
      margin: 0 auto 3.5rem;
    }
    .artists-header p {
      font-size: 0.85rem;
      color: #666;
      line-height: 1.7;
      margin-top: 1rem;
    }
    .artists-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 2rem;
      max-width: 800px;
      margin: 0 auto;
    }
    .artist-card {
      background: #1A1A1A;
      border: 1px solid #222;
      overflow: hidden;
      transition: border-color 0.4s ease, transform 0.3s ease;
    }
    .artist-card:hover {
      border-color: #D4A017;
      transform: translateY(-4px);
    }
    .artist-photo {
      position: relative;
      aspect-ratio: 3/4;
      overflow: hidden;
    }
    .artist-photo img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      filter: grayscale(100%) contrast(1.1);
      transition: filter 0.5s ease;
    }
    .artist-card:hover .artist-photo img {
      filter: grayscale(40%) contrast(1.05);
    }
    .artist-photo-overlay {
      position: absolute;
      bottom: 0;
      left: 0;
      right: 0;
      height: 50%;
      background: linear-gradient(to top, #1A1A1A, transparent);
      pointer-events: none;
    }
    .artist-info {
      padding: 1.5rem;
    }
    .artist-name {
      font-family: 'Roboto Condensed', sans-serif;
      font-size: 1.4rem;
      font-weight: 900;
      text-transform: uppercase;
      letter-spacing: -0.01em;
      margin-bottom: 0.25rem;
    }
    .artist-title {
      font-family: 'Roboto Condensed', sans-serif;
      font-size: 0.6rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.15em;
      color: #D4A017;
      margin-bottom: 0.75rem;
    }
    .artist-bio {
      font-size: 0.8rem;
      color: #777;
      line-height: 1.6;
    }
    .artist-specialties {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
      margin-top: 1rem;
    }
    .artist-specialties span {
      font-family: 'Roboto Condensed', sans-serif;
      font-size: 0.55rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      padding: 0.3rem 0.75rem;
      border: 1px solid #333;
      color: #999;
      transition: border-color 0.3s ease, color 0.3s ease;
    }
    .artist-card:hover .artist-specialties span {
      border-color: #D4A017;
      color: #D4A017;
    }

    /* ── The Studio section ── */
    .studio {
      padding: 6rem 2rem;
      background: #0A0A0A;
    }
    .studio-inner {
      max-width: 1000px;
      margin: 0 auto;
    }
    .studio-header {
      text-align: center;
      margin-bottom: 3rem;
    }
    .studio-header p {
      font-size: 0.85rem;
      color: #666;
      line-height: 1.7;
      max-width: 500px;
      margin: 1rem auto 0;
    }
    .studio-gallery {
      display: grid;
      grid-template-columns: 2fr 1fr;
      grid-template-rows: auto auto;
      gap: 4px;
    }
    .studio-gallery-item {
      position: relative;
      overflow: hidden;
    }
    .studio-gallery-item:first-child {
      grid-row: 1 / 3;
    }
    .studio-gallery-item img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      filter: grayscale(60%) brightness(0.8);
      transition: filter 0.5s ease;
    }
    .studio-gallery-item:hover img {
      filter: grayscale(0%) brightness(1);
    }
    .studio-desc {
      max-width: 600px;
      margin: 3rem auto 0;
      text-align: center;
    }
    .studio-desc p {
      font-size: 0.85rem;
      color: #777;
      line-height: 1.8;
      margin-bottom: 1rem;
    }

    /* ── Stacked Type section ── */
    .stacked-type {
      background: #111;
      color: #FAFAFA;
      padding: 6rem 2rem;
      border-top: 1px solid #222;
      border-bottom: 1px solid #222;
    }
    .stacked-type-inner {
      max-width: 900px;
      margin: 0 auto;
    }
    .stacked-type h2 {
      font-family: 'Roboto Condensed', sans-serif;
      font-size: clamp(3rem, 10vw, 6rem);
      font-weight: 900;
      text-transform: uppercase;
      line-height: 0.95;
      letter-spacing: -0.03em;
      margin-bottom: 2rem;
    }
    .stacked-type h2 span {
      display: block;
      transition: color 0.3s ease, transform 0.3s ease;
      transform-origin: left center;
    }
    .stacked-type h2 span:hover {
      color: #D4A017;
      transform: translateX(8px);
    }
    .stacked-type p {
      font-size: 0.85rem;
      color: #666;
      line-height: 1.7;
      max-width: 500px;
      margin-bottom: 1.5rem;
    }

    /* ── AI Feature ── */
    .ai-section {
      background: #0A0A0A;
      padding: 6rem 2rem;
      text-align: center;
    }
    .ai-section h2 {
      font-family: 'Roboto Condensed', sans-serif;
      font-size: 1.5rem;
      font-weight: 900;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      margin-bottom: 1rem;
      color: #FAFAFA;
    }
    .ai-section p {
      max-width: 480px;
      margin: 0 auto;
      font-size: 0.85rem;
      color: #666;
      line-height: 1.7;
    }
    .ai-badge {
      margin-top: 1.5rem;
      font-size: 0.55rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.12em;
      color: #444;
      transition: color 0.3s ease;
    }
    .ai-badge:hover { color: #D4A017; }

    /* ── Footer ── */
    .footer {
      background: #111;
      color: #FAFAFA;
      padding: 4rem 2rem;
      border-top: 1px solid #222;
    }
    .footer-inner {
      max-width: 900px;
      margin: 0 auto;
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
    }
    .footer-brand {
      font-family: 'Roboto Condensed', sans-serif;
      font-size: 1.5rem;
      font-weight: 900;
      text-transform: uppercase;
    }
    .footer-col p {
      font-size: 0.75rem;
      color: #666;
      line-height: 1.8;
    }
    .footer-col a {
      color: #D4A017;
      transition: color 0.3s ease, opacity 0.3s ease;
    }
    .footer-col a:hover { text-decoration: underline; opacity: 0.8; }
    .footer-bottom {
      max-width: 900px;
      margin: 2rem auto 0;
      padding-top: 1.5rem;
      border-top: 1px solid #222;
      font-size: 0.6rem;
      color: #444;
      text-align: center;
    }

    /* ── CTA Badge ── */
    .cta-badge {
      position: fixed;
      bottom: 1rem;
      right: 1rem;
      z-index: 50;
      background: rgba(10,10,10,0.9);
      border: 1px solid #222;
      color: #FAFAFA;
      padding: 0.5rem 1rem;
      border-radius: 999px;
      font-size: 0.7rem;
      backdrop-filter: blur(8px);
      transition: all 0.3s ease;
    }
    .cta-badge:hover { background: #D4A017; color: #0A0A0A; border-color: #D4A017; transform: translateY(-2px); }

    /* ── Mobile ── */
    @media (max-width: 768px) {
      .nav { padding: 1rem 1.5rem; }
      .nav-links { gap: 1rem; }
      .nav-links a:not(.nav-cta) { display: none; }
      .hero h1 { font-size: clamp(2.5rem, 10vw, 4rem); }
      .portfolio-grid { grid-template-columns: repeat(2, 1fr); }
      .artists-grid { grid-template-columns: 1fr; max-width: 400px; }
      .studio-gallery { grid-template-columns: 1fr; }
      .studio-gallery-item:first-child { grid-row: auto; }
      .footer-inner { flex-direction: column; gap: 1.5rem; }
    }

    @media (max-width: 480px) {
      .portfolio-grid { grid-template-columns: repeat(2, 1fr); }
      .hero-sub { font-size: 0.8rem; }
    }
  </style>
</head>
<body>

  <!-- Sticky Nav -->
  <nav class="nav" id="mainNav">
    <div class="nav-brand">Still<span>Water</span></div>
    <div class="nav-links">
      <a href="#portfolio">Work</a>
      <a href="#artists">Artists</a>
      <a href="#studio">Studio</a>
      <a href="#contact" class="nav-cta">Book Now</a>
    </div>
  </nav>

  <!-- Hero - full-bleed editorial -->
  <section class="hero">
    <div class="hero-bg">
      <img src="https://images.pexels.com/photos/955938/pexels-photo-955938.jpeg?auto=compress&cs=tinysrgb&w=1600" alt="Tattoo studio atmosphere" />
    </div>
    <div class="hero-overlay"></div>
    <div class="hero-content">
      <div class="hero-label">Ivanhoe Village, Orlando</div>
      <h1>Home of<em>the craft</em></h1>
      <p class="hero-sub">Still Water is a two-artist custom tattoo studio. Every piece starts with a conversation. No flash. No walk-ins. Just permanent work done right.</p>
      <a href="#contact" class="hero-cta">Book a Consultation</a>
    </div>
    <div class="hero-scroll">
      Scroll
      <span></span>
    </div>
  </section>

  <!-- Portfolio Gallery Grid -->
  <ScrollReveal client:visible>
    <section id="portfolio" class="portfolio">
      <div class="portfolio-header">
        <div class="section-label">Selected Work</div>
        <h2 class="section-heading">The Portfolio</h2>
        <p>Custom pieces designed for the body and the story. Fine line, blackwork, cover-ups, and everything between.</p>
      </div>
      <div class="portfolio-grid">
        <div class="portfolio-item">
          <img src="https://images.pexels.com/photos/4125659/pexels-photo-4125659.jpeg?auto=compress&cs=tinysrgb&w=600" alt="Fine line botanical tattoo" />
          <div class="portfolio-overlay"><span>Fine Line</span></div>
        </div>
        <div class="portfolio-item">
          <img src="https://images.pexels.com/photos/4123051/pexels-photo-4123051.jpeg?auto=compress&cs=tinysrgb&w=600" alt="Blackwork tattoo" />
          <div class="portfolio-overlay"><span>Blackwork</span></div>
        </div>
        <div class="portfolio-item">
          <img src="https://images.pexels.com/photos/955938/pexels-photo-955938.jpeg?auto=compress&cs=tinysrgb&w=600" alt="Custom cover-up" />
          <div class="portfolio-overlay"><span>Cover-Up</span></div>
        </div>
        <div class="portfolio-item">
          <img src="https://images.pexels.com/photos/4125659/pexels-photo-4125659.jpeg?auto=compress&cs=tinysrgb&w=600&h=600&fit=crop&crop=bottom" alt="Geometric tattoo detail" />
          <div class="portfolio-overlay"><span>Geometric</span></div>
        </div>
        <div class="portfolio-item">
          <img src="https://images.pexels.com/photos/4123051/pexels-photo-4123051.jpeg?auto=compress&cs=tinysrgb&w=600&h=600&fit=crop&crop=top" alt="Portrait tattoo" />
          <div class="portfolio-overlay"><span>Portrait</span></div>
        </div>
        <div class="portfolio-item">
          <img src="https://images.pexels.com/photos/955938/pexels-photo-955938.jpeg?auto=compress&cs=tinysrgb&w=600&h=600&fit=crop&crop=center" alt="Botanical tattoo" />
          <div class="portfolio-overlay"><span>Botanical</span></div>
        </div>
      </div>
    </section>
  </ScrollReveal>

  <!-- Artist Profile Cards -->
  <ScrollReveal client:visible>
    <section id="artists" class="artists">
      <div class="artists-header">
        <div class="section-label">Meet the Artists</div>
        <h2 class="section-heading">Two Artists.<br/>One Standard.</h2>
        <p>We don't stack clients. We don't rush. Every appointment gets the time and focus it deserves.</p>
      </div>
      <div class="artists-grid">
        <div class="artist-card">
          <div class="artist-photo">
            <img src="https://images.pexels.com/photos/4125659/pexels-photo-4125659.jpeg?auto=compress&cs=tinysrgb&w=600&h=800&fit=crop" alt="Reina Torres - Fine Line Specialist" />
            <div class="artist-photo-overlay"></div>
          </div>
          <div class="artist-info">
            <div class="artist-name">Reina Torres</div>
            <div class="artist-title">Fine Line Specialist</div>
            <p class="artist-bio">Delicate botanical and geometric work. Precision placement for pieces that age beautifully. 8 years of focused practice.</p>
            <div class="artist-specialties">
              <span>Fine Line</span>
              <span>Botanical</span>
              <span>Geometric</span>
              <span>Micro Realism</span>
            </div>
          </div>
        </div>
        <div class="artist-card">
          <div class="artist-photo">
            <img src="https://images.pexels.com/photos/4123051/pexels-photo-4123051.jpeg?auto=compress&cs=tinysrgb&w=600&h=800&fit=crop" alt="James Oku - Blackwork Master" />
            <div class="artist-photo-overlay"></div>
          </div>
          <div class="artist-info">
            <div class="artist-name">James Oku</div>
            <div class="artist-title">Blackwork Master</div>
            <p class="artist-bio">Bold black and grey compositions built for impact. Portraits, traditional, and custom work that commands attention. 12 years in the craft.</p>
            <div class="artist-specialties">
              <span>Blackwork</span>
              <span>Portraits</span>
              <span>Cover-Ups</span>
              <span>Traditional</span>
            </div>
          </div>
        </div>
      </div>
    </section>
  </ScrollReveal>

  <!-- The Studio -->
  <ScrollReveal client:visible>
    <section id="studio" class="studio">
      <div class="studio-inner">
        <div class="studio-header">
          <div class="section-label">The Space</div>
          <h2 class="section-heading">The Studio</h2>
          <p>A two-artist space on Orange Avenue in Ivanhoe Village. Also a small gallery showing original work from local artists on a rotating basis.</p>
        </div>
        <div class="studio-gallery">
          <div class="studio-gallery-item">
