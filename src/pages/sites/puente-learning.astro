---
/**
 * Puente Learning Academy - Conway, Orlando
 * Inspired by: snack-petal (minimal serif) + Stanford.edu (full-bleed hero,
 * news card grid, alternating image sections, category blocks, sticky nav)
 * Colors: #1A1A1A dark, #5B7F5E green accent, #F5F5F0 cream bg
 */
import ScrollReveal from '../../components/ScrollReveal.tsx';
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Puente Learning Academy | Two Languages. One Future.</title>
  <meta name="description" content="Bilingual tutoring for K-8 students in Conway and East Orlando." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display&family=DM+Sans:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    html { scroll-behavior: smooth; }
    body {
      font-family: 'DM Sans', sans-serif;
      background: #F5F5F0;
      color: #1A1A1A;
      -webkit-font-smoothing: antialiased;
      overflow-x: hidden;
    }
    img { max-width: 100%; display: block; }
    a { color: inherit; text-decoration: none; transition: color 0.3s; }

    /* ── Nav - sticky, Stanford-style ── */
    .nav {
      position: fixed;
      top: 0; left: 0; right: 0;
      z-index: 100;
      padding: 1rem 2.5rem;
      display: flex;
      justify-content: space-between;
      align-items: center;
      transition: background 0.3s, backdrop-filter 0.3s, box-shadow 0.3s;
    }
    .nav.scrolled {
      background: rgba(245,245,240,0.92);
      backdrop-filter: blur(12px);
      box-shadow: 0 1px 0 rgba(0,0,0,0.06);
    }
    .nav-brand {
      font-family: 'DM Serif Display', serif;
      font-size: 1.1rem;
      color: #fff;
      transition: color 0.3s;
    }
    .nav.scrolled .nav-brand { color: #1A1A1A; }
    .nav-links { display: flex; gap: 2rem; }
    .nav-links a {
      font-size: 0.7rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: rgba(255,255,255,0.8);
    }
    .nav.scrolled .nav-links a { color: #888; }
    .nav-links a:hover { color: #5B7F5E; }

    /* ── Hero - full-bleed dark like Stanford ── */
    .hero {
      position: relative;
      min-height: 85vh;
      display: flex;
      align-items: center;
      justify-content: center;
      overflow: hidden;
      background: #1A1A1A;
    }
    .hero-bg {
      position: absolute;
      inset: 0;
    }
    .hero-bg img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      opacity: 0.5;
    }
    .hero-gradient {
      position: absolute;
      inset: 0;
      background: linear-gradient(to bottom, rgba(26,26,26,0.3) 0%, rgba(26,26,26,0.7) 100%);
    }
    .hero-content {
      position: relative;
      z-index: 2;
      text-align: center;
      padding: 6rem 2rem 4rem;
      max-width: 700px;
    }
    .hero-label {
      font-size: 0.65rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.2em;
      color: #5B7F5E;
      margin-bottom: 1.5rem;
    }
    .hero-content h1 {
      font-family: 'DM Serif Display', serif;
      font-size: clamp(2.8rem, 7vw, 4.5rem);
      font-weight: 400;
      line-height: 1.1;
      color: #fff;
      margin-bottom: 1rem;
    }
    .hero-sub {
      font-size: 1rem;
      color: rgba(255,255,255,0.7);
      margin-bottom: 2rem;
      line-height: 1.6;
    }
    .hero-cta {
      display: inline-block;
      background: #5B7F5E;
      color: #fff;
      padding: 0.9rem 2.5rem;
      font-size: 0.7rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      border-radius: 4px;
      transition: all 0.3s;
    }
    .hero-cta:hover { background: #4A6B4D; transform: translateY(-2px); }

    /* ── Mission statement - Stanford "A Mission Defined" style ── */
    .mission {
      max-width: 750px;
      margin: 0 auto;
      padding: 5rem 2rem;
      text-align: center;
    }
    .mission-label {
      font-size: 0.6rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.2em;
      color: #5B7F5E;
      margin-bottom: 1.5rem;
    }
    .mission h2 {
      font-family: 'DM Serif Display', serif;
      font-size: clamp(1.5rem, 4vw, 2.2rem);
      font-weight: 400;
      line-height: 1.4;
      color: #1A1A1A;
    }

    /* ── News/Program cards - Stanford 3-column grid ── */
    .card-section {
      max-width: 1000px;
      margin: 0 auto;
      padding: 0 2rem 5rem;
    }
    .card-section-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 2rem;
      padding-bottom: 1rem;
      border-bottom: 2px solid #1A1A1A;
    }
    .card-section-header h2 {
      font-family: 'DM Serif Display', serif;
      font-size: 1.4rem;
      font-weight: 400;
    }
    .card-section-header a {
      font-size: 0.65rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: #5B7F5E;
    }
    .card-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1.5rem;
    }
    .card {
      transition: transform 0.3s;
    }
    .card:hover { transform: translateY(-4px); }
    .card-img {
      overflow: hidden;
      border-radius: 4px;
      margin-bottom: 1rem;
      aspect-ratio: 4/3;
    }
    .card-img img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform 0.5s;
    }
    .card:hover .card-img img { transform: scale(1.05); }
    .card-tag {
      font-size: 0.55rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: #5B7F5E;
      margin-bottom: 0.4rem;
    }
    .card h3 {
      font-family: 'DM Serif Display', serif;
      font-size: 1rem;
      font-weight: 400;
      line-height: 1.3;
      margin-bottom: 0.4rem;
    }
    .card p {
      font-size: 0.75rem;
      color: #888;
      line-height: 1.6;
    }

    /* ── Alternating feature sections - Stanford style ── */
    .feature {
      display: grid;
      grid-template-columns: 1fr 1fr;
      min-height: 450px;
    }
    .feature-img {
      overflow: hidden;
    }
    .feature-img img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }
    .feature-text {
      display: flex;
      flex-direction: column;
      justify-content: center;
      padding: 4rem 3rem;
    }
    .feature-text.dark {
      background: #1A1A1A;
      color: #fff;
    }
    .feature-text.light {
      background: #F5F5F0;
    }
    .feature-label {
      font-size: 0.6rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.15em;
      color: #5B7F5E;
      margin-bottom: 1rem;
    }
    .feature-text h2 {
      font-family: 'DM Serif Display', serif;
      font-size: clamp(1.4rem, 3vw, 2rem);
      font-weight: 400;
      line-height: 1.2;
      margin-bottom: 1rem;
    }
    .feature-text p {
      font-size: 0.85rem;
      line-height: 1.7;
      color: #888;
      margin-bottom: 1.5rem;
    }
    .feature-text.dark p { color: rgba(255,255,255,0.5); }
    .feature-link {
      font-size: 0.65rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: #5B7F5E;
    }
    .feature-link:hover { text-decoration: underline; }

    /* ── Stats row - Stanford-inspired ── */
    .stats {
      background: #1A1A1A;
      padding: 4rem 2rem;
    }
    .stats-inner {
      max-width: 900px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 2rem;
      text-align: center;
    }
    .stat-number {
      font-family: 'DM Serif Display', serif;
      font-size: 2.5rem;
      color: #5B7F5E;
      margin-bottom: 0.25rem;
    }
    .stat-label {
      font-size: 0.65rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: rgba(255,255,255,0.4);
    }

    /* ── Testimonials ── */
    .testimonials {
      max-width: 700px;
      margin: 0 auto;
      padding: 5rem 2rem;
    }
    .testimonials h2 {
      font-family: 'DM Serif Display', serif;
      font-size: clamp(1.5rem, 4vw, 2rem);
      font-weight: 400;
      text-align: center;
      margin-bottom: 3rem;
    }
    .testimonial {
      text-align: center;
      padding: 2rem 0;
      border-top: 1px solid #D5D5CF;
    }
    .testimonial-quote {
      font-family: 'DM Serif Display', serif;
      font-size: 1.05rem;
      font-style: italic;
      line-height: 1.6;
      color: #333;
      max-width: 520px;
      margin: 0 auto 1rem;
    }
    .testimonial-name {
      font-size: 0.7rem;
      font-weight: 700;
      color: #1A1A1A;
    }
    .testimonial-role {
      font-size: 0.65rem;
      color: #999;
    }

    /* ── AI Section ── */
    .ai-section {
      background: #5B7F5E;
      color: #fff;
      text-align: center;
      padding: 5rem 2rem;
    }
    .ai-section .label {
      font-size: 0.55rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.2em;
      color: rgba(255,255,255,0.6);
      margin-bottom: 0.75rem;
    }
    .ai-section h3 {
      font-family: 'DM Serif Display', serif;
      font-size: 1.3rem;
      font-weight: 400;
      margin-bottom: 1rem;
    }
    .ai-section p {
      font-size: 0.85rem;
      color: rgba(255,255,255,0.6);
      line-height: 1.7;
      max-width: 500px;
      margin: 0 auto;
    }
    .ai-badge {
      margin-top: 1.5rem;
      font-size: 0.5rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.12em;
      color: rgba(255,255,255,0.25);
    }

    /* ── CTA ── */
    .cta-section {
      text-align: center;
      padding: 5rem 2rem;
    }
    .cta-section h2 {
      font-family: 'DM Serif Display', serif;
      font-size: clamp(1.8rem, 5vw, 2.8rem);
      font-weight: 400;
      color: #1A1A1A;
      margin-bottom: 1rem;
    }
    .cta-section p {
      font-size: 0.85rem;
      color: #888;
      margin-bottom: 2rem;
    }

    /* ── Footer ── */
    .footer {
      background: #1A1A1A;
      color: #999;
      padding: 3rem 2.5rem;
    }
    .footer-inner {
      max-width: 900px;
      margin: 0 auto;
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      gap: 2rem;
    }
    .footer-brand {
      font-family: 'DM Serif Display', serif;
      font-size: 1rem;
      color: #F5F5F0;
      margin-bottom: 0.5rem;
    }
    .footer-col p {
      font-size: 0.75rem;
      line-height: 1.8;
      color: #666;
    }
    .footer-col a { color: #5B7F5E; }
    .footer-col a:hover { color: #F5F5F0; }
    .footer-copy {
      max-width: 900px;
      margin: 2rem auto 0;
      padding-top: 1.5rem;
      border-top: 1px solid #333;
      text-align: center;
      font-size: 0.6rem;
      color: #555;
    }
    .footer-copy a { color: #5B7F5E; }

    .cta-badge {
      position: fixed;
      bottom: 1rem;
      right: 1rem;
      z-index: 50;
      background: rgba(26,26,26,0.9);
      color: #F5F5F0;
      padding: 0.5rem 1rem;
      border-radius: 999px;
      font-size: 0.7rem;
      backdrop-filter: blur(8px);
      transition: all 0.3s;
    }
    .cta-badge:hover { background: #5B7F5E; }

    /* ── Responsive ── */
    @media (max-width: 768px) {
      .card-grid { grid-template-columns: 1fr; }
      .feature { grid-template-columns: 1fr; }
      .feature-img { height: 300px; }
      .stats-inner { grid-template-columns: repeat(2, 1fr); }
      .footer-inner { flex-direction: column; }
      .nav-links { gap: 1rem; }
    }
  </style>
</head>
<body>

  <!-- Sticky Nav -->
  <nav class="nav">
    <div class="nav-brand">Puente Learning</div>
    <div class="nav-links">
      <a href="#programs">Programs</a>
      <a href="#about">About</a>
      <a href="#families">Families</a>
      <a href="#enroll">Enroll</a>
    </div>
  </nav>

  <!-- Hero - Stanford full-bleed -->
  <section class="hero">
    <div class="hero-bg">
      <img src="https://images.pexels.com/photos/8613089/pexels-photo-8613089.jpeg?auto=compress&cs=tinysrgb&w=1400" alt="Children learning in classroom" loading="eager" />
    </div>
    <div class="hero-gradient"></div>
    <div class="hero-content">
      <div class="hero-label">Bilingual Education &middot; Conway, Orlando</div>
      <h1>Two Languages. One Future.</h1>
      <div class="hero-sub">K-8 bilingual tutoring that builds confidence in English and Spanish. Small groups, credentialed tutors, real results.</div>
      <a href="#enroll" class="hero-cta">Enroll Your Child</a>
    </div>
  </section>

  <!-- Mission -->
  <ScrollReveal client:load>
    <section class="mission">
      <div class="mission-label">Our Mission</div>
      <h2>Every bilingual child deserves a learning environment that honors both languages. We don't make kids choose -- we make them stronger in both.</h2>
    </section>
  </ScrollReveal>

  <!-- Program Cards - Stanford news grid -->
  <ScrollReveal client:load>
    <section class="card-section" id="programs">
      <div class="card-section-header">
        <h2>Our Programs</h2>
        <a href="#enroll">View All &rarr;</a>
      </div>
      <div class="card-grid">
        <div class="card">
          <div class="card-img">
            <img src="https://images.pexels.com/photos/8612990/pexels-photo-8612990.jpeg?auto=compress&cs=tinysrgb&w=600" alt="Student reading" loading="lazy" />
          </div>
          <div class="card-tag">After School</div>
          <h3>K-8 Bilingual Tutoring</h3>
          <p>Monday-Thursday, 3:30-6pm. Reading, math, and writing in English and Spanish.</p>
        </div>
        <div class="card">
          <div class="card-img">
            <img src="https://images.pexels.com/photos/5905700/pexels-photo-5905700.jpeg?auto=compress&cs=tinysrgb&w=600" alt="Math tutoring" loading="lazy" />
          </div>
          <div class="card-tag">Intervention</div>
          <h3>Reading & Math Support</h3>
          <p>Targeted programs for students below grade level. Close gaps without making kids feel behind.</p>
        </div>
        <div class="card">
          <div class="card-img">
            <img src="https://images.pexels.com/photos/8613312/pexels-photo-8613312.jpeg?auto=compress&cs=tinysrgb&w=600" alt="STEM project" loading="lazy" />
          </div>
          <div class="card-tag">Summer</div>
          <h3>Enrichment Camps</h3>
          <p>Six-week summer program combining academics with hands-on STEM projects.</p>
        </div>
      </div>
    </section>
  </ScrollReveal>

  <!-- Feature: About - alternating image/text like Stanford -->
  <ScrollReveal client:load>
    <section class="feature" id="about">
      <div class="feature-img">
        <img src="https://images.pexels.com/photos/3769981/pexels-photo-3769981.jpeg?auto=compress&cs=tinysrgb&w=800" alt="Tutor helping student" loading="lazy" />
      </div>
      <div class="feature-text dark">
        <div class="feature-label">Our Story</div>
        <h2>Founded by a Teacher Who Saw the Gap</h2>
        <p>Carmen Delgado spent 12 years in Orange County Public Schools watching bilingual kids fall through the cracks. Puente was born to catch them.</p>
        <p>Our tutors are bilingual, credentialed, and from Conway, Azalea Park, and Meadow Woods -- the same communities we serve.</p>
        <a href="#enroll" class="feature-link">Meet Our Team &rarr;</a>
      </div>
    </section>
  </ScrollReveal>

  <ScrollReveal client:load>
    <section class="feature">
      <div class="feature-text light">
        <div class="feature-label">Parent Workshops</div>
        <h2>Helping Parents Navigate the System</h2>
        <p>Monthly workshops in Spanish and English. Understand report cards, advocate at conferences, and support learning at home.</p>
        <a href="#enroll" class="feature-link">Learn More &rarr;</a>
      </div>
      <div class="feature-img">
        <img src="https://images.pexels.com/photos/7551442/pexels-photo-7551442.jpeg?auto=compress&cs=tinysrgb&w=800" alt="Parent and child learning" loading="lazy" />
      </div>
    </section>
  </ScrollReveal>

  <!-- Stats -->
  <ScrollReveal client:load>
    <section class="stats">
      <div class="stats-inner">
        <div>
          <div class="stat-number">200+</div>
          <div class="stat-label">Students Served</div>
        </div>
        <div>
          <div class="stat-number">94%</div>
          <div class="stat-label">Grade Improvement</div>
        </div>
        <div>
          <div class="stat-number">12</div>
          <div class="stat-label">Bilingual Tutors</div>
        </div>
        <div>
          <div class="stat-number">3</div>
          <div class="stat-label">Communities</div>
        </div>
      </div>
    </section>
  </ScrollReveal>

  <!-- Testimonials -->
  <section class="testimonials" id="families">
    <h2>From Our Families</h2>
    <ScrollReveal client:load>
      <div class="testimonial">
        <div class="testimonial-quote">"My daughter went from dreading reading to asking for books. Carmen and her team changed everything for us."</div>
        <div class="testimonial-name">Rosa M.</div>
        <div class="testimonial-role">Parent, Conway</div>
      </div>
    </ScrollReveal>
    <ScrollReveal client:load delay={0.1}>
      <div class="testimonial">
        <div class="testimonial-quote">"The bilingual approach means my son doesn't have to choose. He's getting stronger in both languages at the same time."</div>
        <div class="testimonial-name">Eduardo S.</div>
        <div class="testimonial-role">Parent, Azalea Park</div>
      </div>
    </ScrollReveal>
    <ScrollReveal client:load delay={0.2}>
      <div class="testimonial">
        <div class="testimonial-quote">"The parent workshops helped me understand how to talk to my child's teacher. That alone was worth it."</div>
        <div class="testimonial-name">Lucia T.</div>
        <div class="testimonial-role">Parent, Meadow Woods</div>
      </div>
    </ScrollReveal>
  </section>

  <!-- AI Section - green accent block -->
  <ScrollReveal client:load>
    <section class="ai-section">
      <div class="label">Powered by AI</div>
      <h3>Automated Bilingual Progress Reports</h3>
      <p>Our system tracks each student's weekly performance and generates progress reports in English and Spanish, sent directly to parents every Friday. No extra admin time for tutors.</p>
      <div class="ai-badge">AI-Ready Architecture by josecustom.ai</div>
    </section>
  </ScrollReveal>

  <!-- CTA -->
  <ScrollReveal client:load>
    <section class="cta-section" id="enroll">
      <h2>All families are welcome here</h2>
      <p>Walk-ins welcome. We'll find the right program for your child.</p>
      <a href="mailto:info@puentelearning.com" class="hero-cta">Enroll Your Child</a>
    </section>
  </ScrollReveal>

  <!-- Footer -->
  <footer class="footer">
    <div class="footer-inner">
      <div class="footer-col">
        <div class="footer-brand">Puente Learning Academy</div>
        <p>Bilingual Education<br />Conway, Orlando</p>
      </div>
      <div class="footer-col">
        <p>4510 S Conway Rd<br />Orlando, FL 32812<br />(407) 555-6241</p>
      </div>
      <div class="footer-col">
        <p><a href="mailto:info@puentelearning.com">info@puentelearning.com</a></p>
      </div>
    </div>
    <div class="footer-copy">
      &copy; 2026 Puente Learning Academy &middot; <a href="https://josecustom.ai/websites" target="_blank" rel="noopener">Built by josecustom.ai</a>
    </div>
  </footer>

  <a href="https://josecustom.ai/websites" target="_blank" rel="noopener" class="cta-badge">josecustom.ai</a>

  <!-- Sticky nav scroll effect -->
  <script>
    const nav = document.querySelector('.nav');
    window.addEventListener('scroll', () => {
      if (window.scrollY > 50) {
        nav.classList.add('scrolled');
      } else {
        nav.classList.remove('scrolled');
      }
    }, { passive: true });
  </script>

</body>
</html>
