---
import { getCollection } from 'astro:content';
import SiteLayout from '../../layouts/SiteLayout.astro';
import NavClassic from '../../components/nav/NavClassic.astro';
import NavCentered from '../../components/nav/NavCentered.astro';
import HeroFullBleed from '../../components/heroes/HeroFullBleed.astro';
import HeroSplit from '../../components/heroes/HeroSplit.astro';
import HeroGradient from '../../components/heroes/HeroGradient.astro';
import FeaturesGrid from '../../components/sections/FeaturesGrid.astro';
import ServicesList from '../../components/sections/ServicesList.astro';
import AboutBio from '../../components/sections/AboutBio.astro';
import Gallery from '../../components/sections/Gallery.astro';
import Testimonials from '../../components/sections/Testimonials.astro';
import AIFeature from '../../components/sections/AIFeature.astro';
import ContactForm from '../../components/sections/ContactForm.astro';
import Footer from '../../components/Footer.astro';
import CTABanner from '../../components/CTABanner.astro';

export async function getStaticPaths() {
  const sites = await getCollection('sites');
  return sites.map(site => ({
    params: { id: site.id },
    props: { site: site.data },
  }));
}

const { site } = Astro.props;

const navComponents = {
  classic: NavClassic,
  centered: NavCentered,
};

const heroComponents = {
  fullbleed: HeroFullBleed,
  split: HeroSplit,
  gradient: HeroGradient,
};

const sectionComponents: Record<string, any> = {
  features: FeaturesGrid,
  services: ServicesList,
  about: AboutBio,
  gallery: Gallery,
  testimonials: Testimonials,
  'ai-feature': AIFeature,
  contact: ContactForm,
};

const NavComponent = navComponents[site.nav.variant];
const HeroComponent = heroComponents[site.hero.variant];
---

<SiteLayout name={site.name} tagline={site.tagline} theme={site.theme}>
  <NavComponent name={site.name} links={site.nav.links} />
  <HeroComponent
    headline={site.hero.headline}
    subheadline={site.hero.subheadline}
    image={site.hero.image}
    ctaText={site.hero.ctaText}
    ctaHref={site.hero.ctaHref}
  />
  {site.sections.map(section => {
    const Component = sectionComponents[section.type];
    if (!Component) return null;
    if (section.type === 'contact') {
      return <Component data={{...section.data, address: site.address, phone: site.phone, email: site.email}} />;
    }
    return <Component data={section.data} />;
  })}
  <Footer name={site.name} address={site.address} phone={site.phone} email={site.email} />
  <CTABanner />
</SiteLayout>
