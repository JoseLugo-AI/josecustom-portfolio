---
/**
 * Stem & Table - Winter Park, Orlando
 * Matched to: grit-editor / Our Blooms template (huge decorative serif title with trademark,
 * monogram nav, numbered services with big standalone numbers, image strip, gradient footer)
 */
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Stem & Table | Seasonal. Intentional. Yours.</title>
  <meta name="description" content="Boutique floral design for Central Florida weddings and events. Winter Park, Orlando." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;0,700;1,400;1,500&family=Nunito+Sans:wght@400;500;600&display=swap" rel="stylesheet" />
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    html { scroll-behavior: smooth; }
    body {
      font-family: 'Nunito Sans', sans-serif;
      background: #FDFAF6;
      color: #2C3E36;
      -webkit-font-smoothing: antialiased;
    }
    img { max-width: 100%; display: block; }
    a { color: inherit; text-decoration: none; }

    /* Nav - monogram left, hamburger right like Our Blooms */
    .nav {
      padding: 1.25rem 2rem;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
    .nav-monogram {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.3rem;
      font-weight: 700;
      color: #2D4A3E;
    }
    .nav-hamburger {
      font-size: 1.2rem;
      color: #2D4A3E;
      cursor: pointer;
    }

    /* HUGE decorative serif title like Our Blooms */
    .hero-title {
      text-align: center;
      padding: 2rem 2rem 0;
    }
    .hero-title h1 {
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(3.5rem, 12vw, 8rem);
      font-weight: 300;
      font-style: italic;
      color: #2D4A3E;
      line-height: 0.95;
      letter-spacing: -0.02em;
    }
    .hero-title h1 sup {
      font-size: 0.3em;
      vertical-align: super;
      font-style: normal;
    }

    /* Hero image with badge like Our Blooms */
    .hero-image {
      max-width: 500px;
      margin: 2rem auto;
      padding: 0 2rem;
      position: relative;
    }
    .hero-image img {
      width: 100%;
      height: 500px;
      object-fit: cover;
    }
    .hero-badge {
      position: absolute;
      top: 1rem;
      left: 2.5rem;
      background: #D4A017;
      color: #fff;
      padding: 0.5rem 0.75rem;
      font-size: 0.6rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      line-height: 1.3;
    }

    /* Who we are intro - centered text like Our Blooms */
    .intro-section {
      text-align: center;
      padding: 4rem 2rem;
      max-width: 550px;
      margin: 0 auto;
    }
    .intro-label {
      font-size: 0.6rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.15em;
      color: #9B6B4A;
      margin-bottom: 1rem;
    }
    .intro-section p {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.2rem;
      font-weight: 400;
      line-height: 1.5;
      color: #2C3E36;
      margin-bottom: 1.5rem;
    }
    .intro-btn {
      display: inline-block;
      border: 1.5px solid #2D4A3E;
      padding: 0.6rem 1.5rem;
      font-size: 0.65rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      transition: all 0.2s;
    }
    .intro-btn:hover { background: #2D4A3E; color: #FDFAF6; }

    /* Image strip - 4 thumbnails like Our Blooms */
    .image-strip {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 4px;
      max-width: 800px;
      margin: 0 auto;
      padding: 0 2rem;
    }
    .image-strip img {
      width: 100%;
      aspect-ratio: 1;
      object-fit: cover;
    }

    /* "What We Do" heading - bold uppercase like Our Blooms */
    .section-heading {
      text-align: center;
      padding: 5rem 2rem 2rem;
    }
    .section-heading h2 {
      font-family: 'Nunito Sans', sans-serif;
      font-size: 0.85rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.15em;
      color: #2D4A3E;
    }
    .section-heading p {
      font-size: 0.8rem;
      color: #888;
      margin-top: 0.5rem;
    }

    /* Numbered services - big standalone numbers like Our Blooms */
    .numbered-service {
      text-align: center;
      padding: 3rem 2rem;
      max-width: 600px;
      margin: 0 auto;
    }
    .service-number {
      font-family: 'Cormorant Garamond', serif;
      font-size: 4rem;
      font-weight: 300;
      color: #D5CFC7;
      line-height: 1;
      margin-bottom: 0.5rem;
    }
    .service-divider {
      width: 40px;
      height: 1px;
      background: #D5CFC7;
      margin: 1.5rem auto;
    }
    .numbered-service h3 {
      font-family: 'Nunito Sans', sans-serif;
      font-size: 0.8rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.12em;
      color: #2D4A3E;
      margin-bottom: 0.75rem;
    }
    .numbered-service p {
      font-size: 0.8rem;
      color: #888;
      line-height: 1.7;
      max-width: 450px;
      margin: 0 auto;
    }

    /* Grow with us CTA - like Our Blooms bottom */
    .grow-section {
      text-align: center;
      padding: 4rem 2rem;
      max-width: 550px;
      margin: 0 auto;
    }
    .grow-label {
      font-size: 0.6rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.15em;
      color: #9B6B4A;
      margin-bottom: 1rem;
    }
    .grow-section p {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.2rem;
      line-height: 1.5;
      color: #2C3E36;
      margin-bottom: 1.5rem;
    }

    /* AI section */
    .ai-section {
      text-align: center;
      padding: 3rem 2rem;
      max-width: 500px;
      margin: 0 auto;
    }
    .ai-section h3 {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.1rem;
      font-weight: 500;
      margin-bottom: 0.5rem;
    }
    .ai-section p {
      font-size: 0.75rem;
      color: #888;
      line-height: 1.7;
    }
    .ai-badge {
      margin-top: 1rem;
      font-size: 0.5rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.12em;
      color: #ccc;
    }

    /* Footer - gradient fade with monogram like Our Blooms */
    .footer {
      background: linear-gradient(to bottom, #FDFAF6 0%, #E8E3DB 100%);
      padding: 4rem 2rem 2rem;
    }
    .footer-inner {
      max-width: 800px;
      margin: 0 auto;
      display: flex;
      justify-content: space-between;
      align-items: flex-end;
    }
    .footer-monogram {
      font-family: 'Cormorant Garamond', serif;
      font-size: 3rem;
      font-weight: 700;
      color: #2D4A3E;
    }
    .footer-right {
      text-align: right;
    }
    .footer-location {
      font-size: 0.7rem;
      color: #888;
      margin-bottom: 0.5rem;
    }
    .footer-links {
      font-size: 0.65rem;
      color: #aaa;
    }
    .footer-links a { color: #9B6B4A; }
    .footer-links a:hover { text-decoration: underline; }
    .footer-copy {
      text-align: center;
      margin-top: 2rem;
      font-size: 0.6rem;
      color: #bbb;
    }
    .footer-copy a { color: #9B6B4A; }

    .cta-badge {
      position: fixed;
      bottom: 1rem;
      right: 1rem;
      z-index: 50;
      background: rgba(45,74,62,0.9);
      border: 1px solid rgba(155,107,74,0.3);
      color: #F2EDE8;
      padding: 0.5rem 1rem;
      border-radius: 999px;
      font-size: 0.7rem;
      backdrop-filter: blur(8px);
      transition: all 0.2s;
    }
    .cta-badge:hover { background: #9B6B4A; border-color: #9B6B4A; }

    @media (max-width: 768px) {
      .image-strip { grid-template-columns: repeat(2, 1fr); }
      .hero-image img { height: 350px; }
      .footer-inner { flex-direction: column; align-items: center; text-align: center; gap: 1rem; }
      .footer-right { text-align: center; }
    }
  </style>
</head>
<body>

  <nav class="nav">
    <div class="nav-monogram">S.T.</div>
    <div class="nav-hamburger">&#9776;</div>
  </nav>

  <section class="hero-title">
    <h1>Stem &<br />Table<sup>&reg;</sup></h1>
  </section>

  <div class="hero-image">
    <img src="https://images.unsplash.com/photo-1487530811176-3780de880c2d?w=800&q=80" alt="Seasonal floral arrangement" />
    <div class="hero-badge">New<br />10% Off Your<br />First Order</div>
  </div>

  <section class="intro-section">
    <div class="intro-label">Who We Are</div>
    <p>We're Stem & Table<sup>&reg;</sup> and we're here to help you find your floral story.</p>
    <a href="#contact" class="intro-btn">About Us</a>
  </section>

  <div class="image-strip">
    <img src="https://images.unsplash.com/photo-1469371670807-013ccf25f16a?w=400&q=80" alt="Wedding arch" />
    <img src="https://images.unsplash.com/photo-1563241527-3004b7be0ffd?w=400&q=80" alt="Bridal bouquet" />
    <img src="https://images.unsplash.com/photo-1522057306606-8d84ae561c1f?w=400&q=80" alt="Centerpiece" />
    <img src="https://images.unsplash.com/photo-1561181286-d3fee7d55364?w=400&q=80" alt="In progress" />
  </div>

  <div class="section-heading">
    <h2>What We Do</h2>
    <p>We bring a touch of that simple magic into your world.</p>
  </div>

  <div class="numbered-service">
    <div class="service-number">1</div>
    <div class="service-divider"></div>
    <h3>Wedding Floral Design</h3>
    <p>Ceremony arches, reception centerpieces, bouquets, boutonnieres, and personal flowers. We limit ourselves to one wedding per weekend so every event gets our full attention.</p>
  </div>

  <div class="numbered-service">
    <div class="service-number">2</div>
    <div class="service-divider"></div>
    <h3>Event Installations & Centerpieces</h3>
    <p>Corporate events, galas, and private parties. Large-scale installations or intimate table arrangements -- scaled to your space and budget.</p>
  </div>

  <div class="numbered-service">
    <div class="service-number">3</div>
    <div class="service-divider"></div>
    <h3>Weekly Fresh Arrangements</h3>
    <p>Standing orders for restaurants, hotels, and offices. Fresh seasonal flowers delivered weekly, arranged on-site. If it's not in season, we'll tell you -- and suggest something better.</p>
  </div>

  <section class="grow-section" id="contact">
    <div class="grow-label">Grow With Us</div>
    <p>Discover how we can add a touch of natural beauty to your next event.</p>
    <a href="mailto:flowers@stemandtable.com" class="intro-btn">About Us</a>
  </section>

  <section class="ai-section">
    <h3>Seasonal Availability & Instant Quoting</h3>
    <p>Select your colors, style, and wedding date. Our system shows what's in season, suggests arrangement options, and generates a ballpark quote before your first consultation. No guesswork, no sticker shock.</p>
    <div class="ai-badge">AI-Ready Architecture by josecustom.ai</div>
  </section>

  <footer class="footer">
    <div class="footer-inner">
      <div class="footer-monogram">S.T.</div>
      <div class="footer-right">
        <div class="footer-location">Winter Park, FL</div>
        <div class="footer-links">
          <a href="mailto:flowers@stemandtable.com">Contact</a>
        </div>
      </div>
    </div>
    <div class="footer-copy">
      &copy; 2026 Stem & Table &middot; 287 W Fairbanks Ave, Winter Park, FL 32789 &middot; (407) 555-3192<br />
      <a href="https://josecustom.ai/websites" target="_blank" rel="noopener">Built by josecustom.ai</a>
    </div>
  </footer>

  <a href="https://josecustom.ai/websites" target="_blank" rel="noopener" class="cta-badge">Demo site by josecustom.ai</a>

</body>
</html>
