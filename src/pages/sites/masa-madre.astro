---
/**
 * Masa Madre Bakehouse - Curry Ford, Orlando
 * Matched to: path-act Figma template (centered single-column, decorative display type,
 * warm cream bg, pill-shaped images, timeline sections, teal footer, poster aesthetic)
 */
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Masa Madre Bakehouse | Scratch-Made Daily</title>
  <meta name="description" content="Fresh bread, pastries, and custom cakes baked every morning on Curry Ford Road, Orlando." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Roboto+Condensed:wght@700;800;900&family=Roboto:wght@400;500;700&family=Playfair+Display:ital,wght@0,700;0,800;0,900;1,700&display=swap" rel="stylesheet" />
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    html { scroll-behavior: smooth; }
    body {
      font-family: 'Roboto', sans-serif;
      background: #FBEAD6;
      color: #2C2C2C;
      -webkit-font-smoothing: antialiased;
    }
    img { max-width: 100%; display: block; }
    a { color: inherit; text-decoration: none; }

    /* ─── Nav: minimal centered, like path-act ─── */
    .nav {
      text-align: center;
      padding: 1.5rem 1.5rem 1rem;
    }
    .nav-links {
      display: flex;
      justify-content: center;
      gap: 2.5rem;
    }
    .nav-links a {
      font-family: 'Roboto Condensed', sans-serif;
      font-size: 0.7rem;
      font-weight: 900;
      text-transform: uppercase;
      letter-spacing: 0.15em;
      color: #2C2C2C;
      transition: color 0.2s;
    }
    .nav-links a:hover { color: #7AA4AD; }

    /* ─── Hero: big decorative display type, poster-like ─── */
    .hero {
      text-align: center;
      padding: 3rem 1.5rem 2rem;
      max-width: 800px;
      margin: 0 auto;
    }
    .hero-emblem {
      width: 100px;
      height: 100px;
      margin: 0 auto 2rem;
      background: #E8C47C;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: 'Playfair Display', serif;
      font-size: 2.5rem;
      font-weight: 900;
      color: #2C2C2C;
      border: 3px solid #2C2C2C;
    }
    .hero h1 {
      font-family: 'Playfair Display', serif;
      font-size: clamp(4rem, 14vw, 9rem);
      font-weight: 900;
      line-height: 0.85;
      color: #2C2C2C;
      text-transform: uppercase;
      letter-spacing: -0.03em;
      margin-bottom: 1.5rem;
    }
    .hero-sub {
      font-family: 'Roboto', sans-serif;
      font-size: 0.7rem;
      text-transform: uppercase;
      letter-spacing: 0.2em;
      color: #666;
      margin-bottom: 2rem;
    }
    .hero-desc {
      max-width: 520px;
      margin: 0 auto 2.5rem;
      font-size: 1rem;
      line-height: 1.7;
      color: #444;
    }

    /* ─── Decorative divider (SVG-like separator) ─── */
    .ornament {
      text-align: center;
      padding: 1.5rem 0;
      font-size: 1.2rem;
      color: #C4632A;
      letter-spacing: 0.5em;
    }

    /* ─── Featured image: large with heavy border-radius (pill/circle) ─── */
    .featured-img {
      max-width: 700px;
      margin: 0 auto;
      padding: 0 1.5rem;
    }
    .featured-img img {
      width: 100%;
      height: 360px;
      object-fit: cover;
      border-radius: 3000px;
    }

    /* ─── Info block: centered uppercase bold details ─── */
    .info-block {
      text-align: center;
      padding: 4rem 1.5rem;
      max-width: 700px;
      margin: 0 auto;
    }
    .info-block h2 {
      font-family: 'Roboto Condensed', sans-serif;
      font-size: clamp(0.8rem, 2vw, 1rem);
      font-weight: 900;
      text-transform: uppercase;
      letter-spacing: 0.12em;
      color: #2C2C2C;
      margin-bottom: 0.5rem;
    }
    .info-block p {
      font-family: 'Roboto Condensed', sans-serif;
      font-size: clamp(1rem, 2.5vw, 1.3rem);
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: #2C2C2C;
      line-height: 1.4;
    }

    /* ─── Gallery: horizontal pill-shaped cards ─── */
    .gallery-section {
      padding: 3rem 1.5rem;
      max-width: 1100px;
      margin: 0 auto;
    }
    .gallery-scroll {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 1rem;
    }
    .gallery-card {
      text-align: center;
    }
    .gallery-card img {
      width: 100%;
      aspect-ratio: 1;
      object-fit: cover;
      border-radius: 3000px;
      margin-bottom: 0.75rem;
    }
    .gallery-card-label {
      font-size: 0.65rem;
      text-transform: uppercase;
      letter-spacing: 0.12em;
      color: #888;
    }
    .gallery-card-title {
      font-family: 'Roboto Condensed', sans-serif;
      font-size: 0.8rem;
      font-weight: 700;
      text-transform: uppercase;
      color: #2C2C2C;
    }

    /* ─── Timeline / Agenda style sections ─── */
    .timeline-section {
      max-width: 700px;
      margin: 0 auto;
      padding: 4rem 1.5rem;
    }
    .timeline-section h2 {
      font-family: 'Roboto Condensed', sans-serif;
      font-size: clamp(1.5rem, 4vw, 2.2rem);
      font-weight: 900;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      text-align: center;
      margin-bottom: 3rem;
      color: #2C2C2C;
    }
    .timeline-item {
      padding: 1.5rem 0;
      border-top: 1px solid rgba(44,44,44,0.15);
    }
    .timeline-time {
      font-family: 'Roboto Condensed', sans-serif;
      font-size: 0.65rem;
      font-weight: 900;
      text-transform: uppercase;
      letter-spacing: 0.15em;
      color: #999;
      margin-bottom: 0.25rem;
    }
    .timeline-title {
      font-family: 'Roboto Condensed', sans-serif;
      font-size: 0.8rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      color: #2C2C2C;
      margin-bottom: 0.5rem;
    }
    .timeline-desc {
      font-size: 0.9rem;
      line-height: 1.7;
      color: #555;
    }

    /* ─── About: full-width text block, centered ─── */
    .about-section {
      max-width: 700px;
      margin: 0 auto;
      padding: 4rem 1.5rem;
      text-align: center;
    }
    .about-section h2 {
      font-family: 'Roboto Condensed', sans-serif;
      font-size: clamp(1.5rem, 4vw, 2.2rem);
      font-weight: 900;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      margin-bottom: 2rem;
      color: #2C2C2C;
    }
    .about-section p {
      font-size: 0.95rem;
      line-height: 1.8;
      color: #444;
      margin-bottom: 1.25rem;
      text-align: left;
    }

    /* ─── AI Feature: dark accent block ─── */
    .ai-section {
      background: #2C2C2C;
      color: #FBEAD6;
      text-align: center;
      padding: 5rem 1.5rem;
    }
    .ai-section h2 {
      font-family: 'Roboto Condensed', sans-serif;
      font-size: clamp(1.2rem, 3vw, 1.8rem);
      font-weight: 900;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      margin-bottom: 1.5rem;
      color: #FBEAD6;
    }
    .ai-section p {
      max-width: 560px;
      margin: 0 auto;
      font-size: 0.9rem;
      line-height: 1.7;
      color: rgba(251,234,214,0.65);
    }
    .ai-badge {
      margin-top: 2rem;
      font-family: 'Roboto Condensed', sans-serif;
      font-size: 0.6rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.15em;
      color: rgba(251,234,214,0.3);
    }

    /* ─── Testimonials: centered quotes ─── */
    .testimonials-section {
      max-width: 650px;
      margin: 0 auto;
      padding: 4rem 1.5rem;
      text-align: center;
    }
    .testimonials-section h2 {
      font-family: 'Roboto Condensed', sans-serif;
      font-size: clamp(1.5rem, 4vw, 2.2rem);
      font-weight: 900;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      margin-bottom: 3rem;
      color: #2C2C2C;
    }
    .testimonial {
      padding: 2rem 0;
      border-top: 1px solid rgba(44,44,44,0.1);
    }
    .testimonial-quote {
      font-family: 'Playfair Display', serif;
      font-size: 1.15rem;
      font-style: italic;
      color: #2C2C2C;
      line-height: 1.6;
      margin-bottom: 1rem;
    }
    .testimonial-name {
      font-family: 'Roboto Condensed', sans-serif;
      font-weight: 700;
      font-size: 0.75rem;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: #2C2C2C;
    }
    .testimonial-role {
      font-size: 0.7rem;
      color: #999;
    }

    /* ─── Contact: centered ─── */
    .contact-section {
      max-width: 500px;
      margin: 0 auto;
      padding: 4rem 1.5rem;
      text-align: center;
    }
    .contact-section h2 {
      font-family: 'Roboto Condensed', sans-serif;
      font-size: clamp(1.5rem, 4vw, 2.2rem);
      font-weight: 900;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      margin-bottom: 1.5rem;
      color: #2C2C2C;
    }
    .contact-details {
      margin-bottom: 2rem;
      font-size: 0.9rem;
      line-height: 2;
      color: #555;
    }
    .contact-details strong {
      font-family: 'Roboto Condensed', sans-serif;
      font-weight: 700;
      color: #2C2C2C;
      text-transform: uppercase;
      font-size: 0.75rem;
      letter-spacing: 0.08em;
    }
    .contact-form input, .contact-form textarea {
      width: 100%;
      padding: 0.9rem 1rem;
      border: 1px solid rgba(44,44,44,0.15);
      background: transparent;
      font-family: 'Roboto', sans-serif;
      font-size: 0.9rem;
      color: #2C2C2C;
      margin-bottom: 0.75rem;
    }
    .contact-form input::placeholder, .contact-form textarea::placeholder { color: #AAA; }
    .contact-form textarea { resize: none; height: 100px; }
    .contact-form button {
      width: 100%;
      background: #2C2C2C;
      color: #FBEAD6;
      border: none;
      padding: 1rem;
      font-family: 'Roboto Condensed', sans-serif;
      font-size: 0.75rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.12em;
      cursor: pointer;
      transition: background 0.2s;
    }
    .contact-form button:hover { background: #444; }

    /* ─── Footer: teal/blue-grey contrast block (key path-act element) ─── */
    .footer {
      background: #7AA4AD;
      color: #fff;
      padding: 3rem 2rem;
    }
    .footer-inner {
      max-width: 900px;
      margin: 0 auto;
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      gap: 2rem;
    }
    .footer-brand {
      font-family: 'Playfair Display', serif;
      font-size: 1.3rem;
      font-weight: 900;
      text-transform: uppercase;
      margin-bottom: 0.5rem;
    }
    .footer-col p {
      font-size: 0.8rem;
      line-height: 1.8;
      color: rgba(255,255,255,0.75);
    }
    .footer-col a { color: #fff; }
    .footer-col a:hover { text-decoration: underline; }
    .footer-bottom {
      max-width: 900px;
      margin: 2rem auto 0;
      padding-top: 1.5rem;
      border-top: 1px solid rgba(255,255,255,0.2);
      display: flex;
      justify-content: space-between;
      font-size: 0.65rem;
      color: rgba(255,255,255,0.5);
    }
    .footer-bottom a { color: rgba(255,255,255,0.7); }
    .footer-bottom a:hover { color: #fff; text-decoration: underline; }

    /* CTA badge */
    .cta-badge {
      position: fixed;
      bottom: 1rem;
      right: 1rem;
      z-index: 50;
      background: rgba(44,44,44,0.9);
      color: #FBEAD6;
      padding: 0.5rem 1rem;
      border-radius: 999px;
      font-size: 0.7rem;
      letter-spacing: 0.05em;
      backdrop-filter: blur(8px);
      transition: background 0.2s;
    }
    .cta-badge:hover { background: #7AA4AD; }

    /* Responsive */
    @media (max-width: 768px) {
      .gallery-scroll { grid-template-columns: repeat(2, 1fr); }
      .footer-inner { flex-direction: column; gap: 1.5rem; }
      .footer-bottom { flex-direction: column; gap: 0.5rem; text-align: center; }
    }
  </style>
</head>
<body>

  <!-- Nav -->
  <nav class="nav">
    <div class="nav-links">
      <a href="#menu">What We Bake</a>
      <a href="#contact">Contact Us</a>
    </div>
  </nav>

  <!-- Hero: big decorative poster-style title -->
  <section class="hero">
    <div class="hero-emblem">M</div>
    <h1>Masa<br />Madre</h1>
    <div class="hero-sub">A Curry Ford Bakehouse &middot; Orlando, FL</div>
    <p class="hero-desc">We invite you to our scratch kitchen, where flour, water, and time come together every morning into bread worth driving across town for.</p>
  </section>

  <!-- Featured image with pill shape -->
  <div class="featured-img">
    <img src="https://images.unsplash.com/photo-1509440159596-0249088772ff?w=1200&q=80" alt="Fresh bread from the oven" />
  </div>

  <!-- Info block: details centered -->
  <div class="info-block">
    <h2>Open Tuesday - Saturday</h2>
    <p>7:00 AM - 4:00 PM</p>
  </div>

  <div class="ornament">&bull; &bull; &bull;</div>

  <div class="info-block" style="padding-top: 0;">
    <h2>Curry Ford Road</h2>
    <p>3245 Curry Ford Rd, Orlando, FL 32806</p>
  </div>

  <div class="ornament">&bull; &bull; &bull;</div>

  <div class="info-block" style="padding-top: 0;">
    <h2>Custom Orders By</h2>
    <p>hello@masamadre.com</p>
  </div>

  <!-- Gallery: circular/pill image cards -->
  <section class="gallery-section">
    <div class="gallery-scroll">
      <div class="gallery-card">
        <img src="https://images.unsplash.com/photo-1549931319-a545753467c8?w=600&q=80" alt="Sourdough loaves" />
        <div class="gallery-card-label">Daily Bake</div>
        <div class="gallery-card-title">Sourdough</div>
      </div>
      <div class="gallery-card">
        <img src="https://images.unsplash.com/photo-1517433670267-08bbd4be890f?w=600&q=80" alt="Croissants" />
        <div class="gallery-card-label">Pastry</div>
        <div class="gallery-card-title">Croissants</div>
      </div>
      <div class="gallery-card">
        <img src="https://images.unsplash.com/photo-1486427944544-d2c246c4df14?w=600&q=80" alt="Custom cake" />
        <div class="gallery-card-label">Custom</div>
        <div class="gallery-card-title">Celebration Cakes</div>
      </div>
      <div class="gallery-card">
        <img src="https://images.unsplash.com/photo-1558961363-fa8fdf82db35?w=600&q=80" alt="Cinnamon rolls" />
        <div class="gallery-card-label">Weekend</div>
        <div class="gallery-card-title">Cinnamon Rolls</div>
      </div>
    </div>
  </section>

  <!-- Menu: timeline/agenda style -->
  <section id="menu" class="timeline-section">
    <h2>What We Bake</h2>
    <div class="timeline-item">
      <div class="timeline-time">Daily &middot; 7am</div>
      <div class="timeline-title">Fresh-Baked Bread & Pastries</div>
      <div class="timeline-desc">Sourdough, ciabatta, brioche, croissants, and seasonal pastries. Daily rotation -- we bake what's right for the day, not what's left from yesterday.</div>
    </div>
    <div class="timeline-item">
      <div class="timeline-time">2 Weeks Notice</div>
      <div class="timeline-title">Custom Cake Orders</div>
      <div class="timeline-desc">Weddings, birthdays, and everything in between. Every cake is designed and decorated in-house.</div>
    </div>
    <div class="timeline-item">
      <div class="timeline-time">Events & Offices</div>
      <div class="timeline-title">Catering Platters</div>
      <div class="timeline-desc">Pastry trays, bread baskets, and dessert spreads for your office, event, or party. We deliver anywhere in East Orlando.</div>
    </div>
    <div class="timeline-item">
      <div class="timeline-time">Sat & Sun &middot; 8am - 1pm</div>
      <div class="timeline-title">Weekend Brunch</div>
      <div class="timeline-desc">Fresh pastries, egg dishes, and our house-made jams. No reservations needed.</div>
    </div>
  </section>

  <!-- About: centered full-width text block -->
  <section class="about-section">
    <h2>About Masa Madre</h2>
    <p>Masa Madre started in 2019 out of a home kitchen on Curry Ford Road. What began as sourdough loaves sold at the Audubon Park Market grew into a full bakehouse serving East Orlando.</p>
    <p>Everything is mixed, shaped, and baked on-site every morning. We source flour from Florida mills when we can and never use preservatives. If it's on the shelf, it was made today.</p>
    <p>Over the years, what started as a weekend hobby has grown into a kitchen that feeds hundreds of families each week. We honor the process -- slow fermentation, real butter, no shortcuts -- because the results speak for themselves.</p>
  </section>

  <!-- AI Feature -->
  <section class="ai-section">
    <h2>Smart Inventory & Order Forecasting</h2>
    <p>Our system tracks daily sales patterns, seasonal demand, and custom order volume to predict exactly how much to prep each morning. Less waste, fewer sellouts, better margins.</p>
    <div class="ai-badge">AI-Ready Architecture by josecustom.ai</div>
  </section>

  <!-- Testimonials -->
  <section class="testimonials-section">
    <h2>Our Neighbors</h2>
    <div class="testimonial">
      <div class="testimonial-quote">"Best sourdough in Orlando. I drive across town for it every Saturday."</div>
      <div class="testimonial-name">Maria C.</div>
      <div class="testimonial-role">Curry Ford regular</div>
    </div>
    <div class="testimonial">
      <div class="testimonial-quote">"They did our wedding cake and it was perfect. Simple, elegant, and actually tasted incredible."</div>
      <div class="testimonial-name">David & Priya T.</div>
      <div class="testimonial-role">Wedding clients</div>
    </div>
    <div class="testimonial">
      <div class="testimonial-quote">"The brunch pastries are unreal. My kids ask to go here every weekend."</div>
      <div class="testimonial-name">Jason W.</div>
      <div class="testimonial-role">Local dad</div>
    </div>
  </section>

  <!-- Contact -->
  <section id="contact" class="contact-section">
    <h2>Come See Us</h2>
    <div class="contact-details">
      <strong>Address</strong><br />
      3245 Curry Ford Rd, Orlando, FL 32806<br /><br />
      <strong>Phone</strong><br />
      (407) 555-2819<br /><br />
      <strong>Email</strong><br />
      hello@masamadre.com
    </div>
    <form class="contact-form" onsubmit="return false;">
      <input type="text" placeholder="Your Name" />
      <input type="email" placeholder="Email Address" />
      <textarea placeholder="Your Message"></textarea>
      <button type="submit">Send Message</button>
    </form>
  </section>

  <!-- Footer: teal contrast (key path-act design element) -->
  <footer class="footer">
    <div class="footer-inner">
      <div class="footer-col">
        <div class="footer-brand">Masa Madre</div>
        <p>A Curry Ford Bakehouse<br />Orlando, Florida</p>
      </div>
      <div class="footer-col">
        <p><strong style="color:#fff;">Hours</strong><br />
        Tue - Sat: 7am - 4pm<br />
        Sun: 8am - 1pm (brunch)<br />
        Mon: Closed</p>
      </div>
      <div class="footer-col">
        <p><strong style="color:#fff;">Contact</strong><br />
        (407) 555-2819<br />
        <a href="mailto:hello@masamadre.com">hello@masamadre.com</a></p>
      </div>
    </div>
    <div class="footer-bottom">
      <span>&copy; 2026 Masa Madre Bakehouse</span>
      <a href="https://josecustom.ai/websites" target="_blank" rel="noopener">Built by josecustom.ai</a>
    </div>
  </footer>

  <a href="https://josecustom.ai/websites" target="_blank" rel="noopener" class="cta-badge">Demo site by josecustom.ai</a>

</body>
</html>
