  <!-- Parallax on featured bread image -->
  <script>
    const breadImg = document.querySelector('.featured-img img');
    if (breadImg) {
      window.addEventListener('scroll', () => {
        const rect = breadImg.getBoundingClientRect();
        const centerY = rect.top + rect.height / 2;
        const viewCenter = window.innerHeight / 2;
        const offset = (centerY - viewCenter) * 0.08;
        breadImg.style.transform = `translateY(${offset}px)`;
      }, { passive: true });
    }
  </script>

