---
/**
 * Masa Madre Bakehouse - Curry Ford, Orlando
 * Inspired by: path-act template (warm cream, poster aesthetic, pill images, timeline)
 * Our take: warm artisan feel with scroll animations, parallax bread hero,
 * interactive gallery, staggered timeline reveals
 */
import ScrollReveal from '../../components/ScrollReveal.tsx';
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Masa Madre Bakehouse | Scratch-Made Daily</title>
  <meta name="description" content="Fresh bread, pastries, and custom cakes baked every morning on Curry Ford Road, Orlando." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;0,800;0,900;1,400;1,700&family=Roboto+Condensed:wght@700;800;900&family=Roboto:wght@400;500&display=swap" rel="stylesheet" />
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    html { scroll-behavior: smooth; }
    body {
      font-family: 'Roboto', sans-serif;
      background: #FBEAD6;
      color: #2C2C2C;
      -webkit-font-smoothing: antialiased;
      overflow-x: hidden;
    }
    img { max-width: 100%; display: block; }
    a { color: inherit; text-decoration: none; }

    /* ── Nav ── */
    .nav {
      text-align: center;
      padding: 1.5rem 1.5rem 1rem;
    }
    .nav-links {
      display: flex;
      justify-content: center;
      gap: 2.5rem;
    }
    .nav-links a {
      font-family: 'Roboto Condensed', sans-serif;
      font-size: 0.7rem;
      font-weight: 900;
      text-transform: uppercase;
      letter-spacing: 0.15em;
      color: #2C2C2C;
      transition: color 0.2s;
    }
    .nav-links a:hover { color: #C4632A; }

    /* ── Hero ── */
    .hero {
      text-align: center;
      padding: 3rem 1.5rem 2rem;
      max-width: 800px;
      margin: 0 auto;
    }
    @keyframes emblem-in {
      0% { transform: scale(0.5) rotate(-180deg); opacity: 0; }
      100% { transform: scale(1) rotate(0deg); opacity: 1; }
    }
    .hero-emblem {
      width: 100px;
      height: 100px;
      margin: 0 auto 2rem;
      background: #E8C47C;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: 'Playfair Display', serif;
      font-size: 2.5rem;
      font-weight: 900;
      color: #2C2C2C;
      border: 3px solid #2C2C2C;
      animation: emblem-in 0.8s cubic-bezier(0.34, 1.56, 0.64, 1) 0.2s both;
    }
    .hero h1 {
      font-family: 'Playfair Display', serif;
      font-size: clamp(4rem, 14vw, 9rem);
      font-weight: 900;
      line-height: 0.85;
      color: #2C2C2C;
      text-transform: uppercase;
      letter-spacing: -0.03em;
      margin-bottom: 1.5rem;
    }
    .hero-sub {
      font-family: 'Roboto', sans-serif;
      font-size: 0.7rem;
      text-transform: uppercase;
      letter-spacing: 0.2em;
      color: #999;
      margin-bottom: 2rem;
    }
    .hero-desc {
      max-width: 520px;
      margin: 0 auto;
      font-size: 1rem;
      line-height: 1.7;
      color: #666;
      font-style: italic;
    }

    /* ── Ornament divider ── */
    .ornament {
      text-align: center;
      padding: 1.5rem 0;
      font-size: 1.2rem;
      color: #C4632A;
      letter-spacing: 0.5em;
    }

    /* ── Featured image with parallax wrapper ── */
    .featured-img {
      max-width: 700px;
      margin: 2rem auto 0;
      padding: 0 1.5rem;
      overflow: hidden;
    }
    .featured-img img {
      width: 100%;
      height: 360px;
      object-fit: cover;
      border-radius: 3000px;
      transition: transform 0.4s ease;
    }
    .featured-img:hover img {
      transform: scale(1.03);
    }

    /* ── Info blocks ── */
    .info-block {
      text-align: center;
      padding: 3.5rem 1.5rem;
      max-width: 700px;
      margin: 0 auto;
    }
    .info-block h2 {
      font-family: 'Roboto Condensed', sans-serif;
      font-size: clamp(0.75rem, 1.8vw, 0.9rem);
      font-weight: 900;
      text-transform: uppercase;
      letter-spacing: 0.15em;
      color: #C4632A;
      margin-bottom: 0.5rem;
    }
    .info-block p {
      font-family: 'Roboto Condensed', sans-serif;
      font-size: clamp(1rem, 2.5vw, 1.3rem);
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: #2C2C2C;
      line-height: 1.4;
    }

    /* ── Gallery: circular cards with hover ── */
    .gallery-section {
      padding: 3rem 1.5rem;
      max-width: 1000px;
      margin: 0 auto;
    }
    .gallery-scroll {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 1.5rem;
    }
    .gallery-card {
      text-align: center;
      transition: transform 0.3s ease;
    }
    .gallery-card:hover { transform: translateY(-6px); }
    .gallery-card-img {
      position: relative;
      overflow: hidden;
      border-radius: 50%;
      margin-bottom: 0.75rem;
    }
    .gallery-card-img img {
      width: 100%;
      aspect-ratio: 1;
      object-fit: cover;
      border-radius: 50%;
      transition: transform 0.5s ease;
    }
    .gallery-card:hover .gallery-card-img img {
      transform: scale(1.08);
    }
    .gallery-card-img::after {
      content: '';
      position: absolute;
      inset: 0;
      border-radius: 50%;
      box-shadow: inset 0 0 0 0 rgba(196, 99, 42, 0);
      transition: box-shadow 0.3s;
    }
    .gallery-card:hover .gallery-card-img::after {
      box-shadow: inset 0 0 0 4px rgba(196, 99, 42, 0.4);
    }
    .gallery-card-label {
      font-size: 0.6rem;
      text-transform: uppercase;
      letter-spacing: 0.12em;
      color: #C4632A;
    }
    .gallery-card-title {
      font-family: 'Roboto Condensed', sans-serif;
      font-size: 0.8rem;
      font-weight: 700;
      text-transform: uppercase;
      color: #2C2C2C;
    }

    /* ── Timeline / Menu ── */
    .timeline-section {
      max-width: 700px;
      margin: 0 auto;
      padding: 4rem 1.5rem;
    }
    .timeline-section h2 {
      font-family: 'Playfair Display', serif;
      font-size: clamp(1.8rem, 5vw, 2.8rem);
      font-weight: 900;
      text-transform: uppercase;
      letter-spacing: 0.03em;
      text-align: center;
      margin-bottom: 3rem;
      color: #2C2C2C;
    }
    .timeline-item {
      padding: 1.5rem 0;
      border-top: 1px solid rgba(44,44,44,0.12);
      display: grid;
      grid-template-columns: 140px 1fr;
      gap: 1.5rem;
      align-items: start;
    }
    .timeline-item:last-child { border-bottom: 1px solid rgba(44,44,44,0.12); }
    .timeline-time {
      font-family: 'Roboto Condensed', sans-serif;
      font-size: 0.6rem;
      font-weight: 900;
      text-transform: uppercase;
      letter-spacing: 0.12em;
      color: #C4632A;
      padding-top: 0.15rem;
    }
    .timeline-title {
      font-family: 'Roboto Condensed', sans-serif;
      font-size: 0.85rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.03em;
      color: #2C2C2C;
      margin-bottom: 0.4rem;
    }
    .timeline-desc {
      font-size: 0.85rem;
      line-height: 1.7;
      color: #777;
    }

    /* ── About ── */
    .about-section {
      max-width: 700px;
      margin: 0 auto;
      padding: 4rem 1.5rem;
    }
    .about-section h2 {
      font-family: 'Playfair Display', serif;
      font-size: clamp(1.8rem, 5vw, 2.8rem);
      font-weight: 900;
      text-transform: uppercase;
      letter-spacing: 0.03em;
      text-align: center;
      margin-bottom: 2rem;
      color: #2C2C2C;
    }
    .about-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 2.5rem;
      align-items: start;
    }
    .about-text p {
      font-size: 0.9rem;
      line-height: 1.8;
      color: #666;
      margin-bottom: 1rem;
    }
    .about-image {
      border-radius: 3000px;
      overflow: hidden;
    }
    .about-image img {
      width: 100%;
      aspect-ratio: 3/4;
      object-fit: cover;
    }

    /* ── AI Feature: dark accent ── */
    .ai-section {
      background: #2C2C2C;
      color: #FBEAD6;
      text-align: center;
      padding: 5rem 1.5rem;
    }
    .ai-section .label {
      font-family: 'Roboto Condensed', sans-serif;
      font-size: 0.55rem;
      font-weight: 900;
      text-transform: uppercase;
      letter-spacing: 0.2em;
      color: #C4632A;
      margin-bottom: 0.75rem;
    }
    .ai-section h2 {
      font-family: 'Playfair Display', serif;
      font-size: clamp(1.2rem, 3vw, 1.8rem);
      font-weight: 900;
      text-transform: uppercase;
      letter-spacing: 0.03em;
      margin-bottom: 1.5rem;
      color: #FBEAD6;
    }
    .ai-section p {
      max-width: 560px;
      margin: 0 auto;
      font-size: 0.9rem;
      line-height: 1.7;
      color: rgba(251,234,214,0.55);
    }
    .ai-badge {
      margin-top: 2rem;
      font-family: 'Roboto Condensed', sans-serif;
      font-size: 0.55rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.15em;
      color: rgba(251,234,214,0.25);
    }

    /* ── Testimonials ── */
    .testimonials-section {
      max-width: 650px;
      margin: 0 auto;
      padding: 4rem 1.5rem;
      text-align: center;
    }
    .testimonials-section h2 {
      font-family: 'Playfair Display', serif;
      font-size: clamp(1.8rem, 5vw, 2.8rem);
      font-weight: 900;
      text-transform: uppercase;
      letter-spacing: 0.03em;
      margin-bottom: 3rem;
      color: #2C2C2C;
    }
    .testimonial {
      padding: 2rem 0;
      border-top: 1px solid rgba(44,44,44,0.1);
    }
    .testimonial-quote {
      font-family: 'Playfair Display', serif;
      font-size: 1.1rem;
      font-style: italic;
      color: #2C2C2C;
      line-height: 1.6;
      margin-bottom: 1rem;
    }
    .testimonial-name {
      font-family: 'Roboto Condensed', sans-serif;
      font-weight: 700;
      font-size: 0.7rem;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: #C4632A;
    }
    .testimonial-role {
      font-size: 0.65rem;
      color: #999;
    }

    /* ── Contact ── */
    .contact-section {
      max-width: 500px;
      margin: 0 auto;
      padding: 4rem 1.5rem;
      text-align: center;
    }
    .contact-section h2 {
      font-family: 'Playfair Display', serif;
      font-size: clamp(1.8rem, 5vw, 2.8rem);
      font-weight: 900;
      text-transform: uppercase;
      letter-spacing: 0.03em;
      margin-bottom: 1.5rem;
      color: #2C2C2C;
    }
    .contact-details {
      margin-bottom: 2rem;
      font-size: 0.85rem;
      line-height: 2;
      color: #777;
    }
    .contact-details strong {
      font-family: 'Roboto Condensed', sans-serif;
      font-weight: 700;
      color: #C4632A;
      text-transform: uppercase;
      font-size: 0.65rem;
      letter-spacing: 0.1em;
    }
    .contact-form input, .contact-form textarea {
      width: 100%;
      padding: 0.9rem 1rem;
      border: 2px solid rgba(44,44,44,0.1);
      border-radius: 6px;
      background: rgba(255,255,255,0.5);
      font-family: 'Roboto', sans-serif;
      font-size: 0.85rem;
      color: #2C2C2C;
      margin-bottom: 0.75rem;
      transition: border-color 0.2s;
    }
    .contact-form input:focus, .contact-form textarea:focus {
      outline: none;
      border-color: #C4632A;
    }
    .contact-form input::placeholder, .contact-form textarea::placeholder { color: #bbb; }
    .contact-form textarea { resize: none; height: 100px; }
    .contact-form button {
      width: 100%;
      background: #2C2C2C;
      color: #FBEAD6;
      border: none;
      padding: 1rem;
      border-radius: 6px;
      font-family: 'Roboto Condensed', sans-serif;
      font-size: 0.75rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.12em;
      cursor: pointer;
      transition: background 0.2s, transform 0.2s;
    }
    .contact-form button:hover { background: #C4632A; transform: translateY(-2px); }

    /* ── Footer: teal ── */
    .footer {
      background: #7AA4AD;
      color: #fff;
      padding: 3rem 2rem;
    }
    .footer-inner {
      max-width: 900px;
      margin: 0 auto;
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      gap: 2rem;
    }
    .footer-brand {
      font-family: 'Playfair Display', serif;
      font-size: 1.3rem;
      font-weight: 900;
      text-transform: uppercase;
      margin-bottom: 0.5rem;
    }
    .footer-col p {
      font-size: 0.8rem;
      line-height: 1.8;
      color: rgba(255,255,255,0.75);
    }
    .footer-col a { color: #fff; }
    .footer-col a:hover { text-decoration: underline; }
    .footer-bottom {
      max-width: 900px;
      margin: 2rem auto 0;
      padding-top: 1.5rem;
      border-top: 1px solid rgba(255,255,255,0.2);
      display: flex;
      justify-content: space-between;
      font-size: 0.6rem;
      color: rgba(255,255,255,0.5);
    }
    .footer-bottom a { color: rgba(255,255,255,0.7); }
    .footer-bottom a:hover { color: #fff; }

    /* ── CTA badge ── */
    .cta-badge {
      position: fixed;
      bottom: 1rem;
      right: 1rem;
      z-index: 50;
      background: rgba(44,44,44,0.9);
      color: #FBEAD6;
      padding: 0.5rem 1rem;
      border-radius: 999px;
      font-size: 0.7rem;
      backdrop-filter: blur(8px);
      transition: background 0.2s;
    }
    .cta-badge:hover { background: #C4632A; }

    /* ── Responsive ── */
    @media (max-width: 768px) {
      .gallery-scroll { grid-template-columns: repeat(2, 1fr); }
      .timeline-item { grid-template-columns: 1fr; gap: 0.5rem; }
      .about-grid { grid-template-columns: 1fr; }
      .about-image { max-width: 300px; margin: 0 auto; }
      .footer-inner { flex-direction: column; gap: 1.5rem; }
      .footer-bottom { flex-direction: column; gap: 0.5rem; text-align: center; }
    }
  </style>
</head>
<body>

  <!-- Nav -->
  <nav class="nav">
    <div class="nav-links">
      <a href="#menu">What We Bake</a>
      <a href="#about">Our Story</a>
      <a href="#contact">Visit Us</a>
    </div>
  </nav>

  <!-- Hero -->
  <section class="hero">
    <div class="hero-emblem">M</div>
    <h1>Masa<br />Madre</h1>
    <div class="hero-sub">A Curry Ford Bakehouse &middot; Orlando, FL</div>
    <p class="hero-desc">We invite you to our scratch kitchen, where flour, water, and time come together every morning into bread worth driving across town for.</p>
  </section>

  <!-- Featured image -->
  <ScrollReveal client:load>
    <div class="featured-img">
      <img src="https://images.unsplash.com/photo-1509440159596-0249088772ff?w=1200&q=80" alt="Fresh bread from the oven" loading="eager" />
    </div>
  </ScrollReveal>

  <!-- Info blocks -->
  <ScrollReveal client:load>
    <div class="info-block">
      <h2>Open Tuesday - Saturday</h2>
      <p>7:00 AM - 4:00 PM</p>
    </div>
  </ScrollReveal>

  <div class="ornament">&bull; &bull; &bull;</div>

  <ScrollReveal client:load>
    <div class="info-block" style="padding-top: 0;">
      <h2>Curry Ford Road</h2>
      <p>3245 Curry Ford Rd, Orlando, FL 32806</p>
    </div>
  </ScrollReveal>

  <div class="ornament">&bull; &bull; &bull;</div>

  <ScrollReveal client:load>
    <div class="info-block" style="padding-top: 0;">
      <h2>Custom Orders By</h2>
      <p>hello@masamadre.com</p>
    </div>
  </ScrollReveal>

  <!-- Gallery -->
  <ScrollReveal client:load>
    <section class="gallery-section">
      <div class="gallery-scroll">
        <div class="gallery-card">
          <div class="gallery-card-img">
            <img src="https://images.unsplash.com/photo-1549931319-a545753467c8?w=600&q=80" alt="Sourdough loaves" loading="lazy" />
          </div>
          <div class="gallery-card-label">Daily Bake</div>
          <div class="gallery-card-title">Sourdough</div>
        </div>
        <div class="gallery-card">
          <div class="gallery-card-img">
            <img src="https://images.unsplash.com/photo-1517433670267-08bbd4be890f?w=600&q=80" alt="Croissants" loading="lazy" />
          </div>
          <div class="gallery-card-label">Pastry</div>
          <div class="gallery-card-title">Croissants</div>
        </div>
        <div class="gallery-card">
          <div class="gallery-card-img">
            <img src="https://images.unsplash.com/photo-1486427944544-d2c246c4df14?w=600&q=80" alt="Custom cake" loading="lazy" />
          </div>
          <div class="gallery-card-label">Custom</div>
          <div class="gallery-card-title">Celebration Cakes</div>
        </div>
        <div class="gallery-card">
          <div class="gallery-card-img">
            <img src="https://images.unsplash.com/photo-1558961363-fa8fdf82db35?w=600&q=80" alt="Cinnamon rolls" loading="lazy" />
          </div>
          <div class="gallery-card-label">Weekend</div>
          <div class="gallery-card-title">Cinnamon Rolls</div>
        </div>
      </div>
    </section>
  </ScrollReveal>

  <!-- Menu Timeline -->
  <section id="menu" class="timeline-section">
    <h2>What We Bake</h2>
    <ScrollReveal client:load>
      <div class="timeline-item">
        <div class="timeline-time">Daily &middot; 7am</div>
        <div>
          <div class="timeline-title">Fresh-Baked Bread & Pastries</div>
          <div class="timeline-desc">Sourdough, ciabatta, brioche, croissants, and seasonal pastries. Daily rotation -- we bake what's right for the day, not what's left from yesterday.</div>
        </div>
      </div>
    </ScrollReveal>
    <ScrollReveal client:load delay={0.1}>
      <div class="timeline-item">
        <div class="timeline-time">2 Weeks Notice</div>
        <div>
          <div class="timeline-title">Custom Cake Orders</div>
          <div class="timeline-desc">Weddings, birthdays, and everything in between. Every cake is designed and decorated in-house.</div>
        </div>
      </div>
    </ScrollReveal>
    <ScrollReveal client:load delay={0.2}>
      <div class="timeline-item">
        <div class="timeline-time">Events & Offices</div>
        <div>
          <div class="timeline-title">Catering Platters</div>
          <div class="timeline-desc">Pastry trays, bread baskets, and dessert spreads for your office, event, or party. We deliver anywhere in East Orlando.</div>
        </div>
      </div>
    </ScrollReveal>
    <ScrollReveal client:load delay={0.3}>
      <div class="timeline-item">
        <div class="timeline-time">Sat & Sun &middot; 8am</div>
        <div>
          <div class="timeline-title">Weekend Brunch</div>
          <div class="timeline-desc">Fresh pastries, egg dishes, and our house-made jams. No reservations needed.</div>
        </div>
      </div>
    </ScrollReveal>
  </section>

  <!-- About -->
  <ScrollReveal client:load>
    <section id="about" class="about-section">
      <h2>About Masa Madre</h2>
      <div class="about-grid">
        <div class="about-text">
          <p>Masa Madre started in 2019 out of a home kitchen on Curry Ford Road. What began as sourdough loaves sold at the Audubon Park Market grew into a full bakehouse serving East Orlando.</p>
          <p>Everything is mixed, shaped, and baked on-site every morning. We source flour from Florida mills when we can and never use preservatives. If it's on the shelf, it was made today.</p>
          <p>Over the years, what started as a weekend hobby has grown into a kitchen that feeds hundreds of families each week. We honor the process -- slow fermentation, real butter, no shortcuts.</p>
        </div>
        <div class="about-image">
          <img src="https://images.pexels.com/photos/5737830/pexels-photo-5737830.jpeg?auto=compress&cs=tinysrgb&w=600" alt="Masa Madre bakehouse owner" loading="lazy" />
        </div>
      </div>
    </section>
  </ScrollReveal>

  <!-- AI Feature -->
  <ScrollReveal client:load>
    <section class="ai-section">
      <div class="label">Powered by AI</div>
      <h2>Smart Inventory & Order Forecasting</h2>
      <p>Our system tracks daily sales patterns, seasonal demand, and custom order volume to predict exactly how much to prep each morning. Less waste, fewer sellouts, better margins.</p>
      <div class="ai-badge">AI-Ready Architecture by josecustom.ai</div>
    </section>
  </ScrollReveal>

  <!-- Testimonials -->
  <section class="testimonials-section">
    <h2>Our Neighbors</h2>
    <ScrollReveal client:load>
      <div class="testimonial">
        <div class="testimonial-quote">"Best sourdough in Orlando. I drive across town for it every Saturday."</div>
        <div class="testimonial-name">Maria C.</div>
        <div class="testimonial-role">Curry Ford regular</div>
      </div>
    </ScrollReveal>
    <ScrollReveal client:load delay={0.1}>
      <div class="testimonial">
        <div class="testimonial-quote">"They did our wedding cake and it was perfect. Simple, elegant, and actually tasted incredible."</div>
        <div class="testimonial-name">David & Priya T.</div>
        <div class="testimonial-role">Wedding clients</div>
      </div>
    </ScrollReveal>
    <ScrollReveal client:load delay={0.2}>
      <div class="testimonial">
        <div class="testimonial-quote">"The brunch pastries are unreal. My kids ask to go here every weekend."</div>
        <div class="testimonial-name">Jason W.</div>
        <div class="testimonial-role">Local dad</div>
      </div>
