---
/**
 * Vero Aesthetics - Winter Park, Orlando
 * Rebuilt: Ama template style + Akanta Ayur spa/resort design elements
 * Serene full-bleed hero, treatment menu with prices, luxurious spa feel,
 * glass nav, results showcase, warm cream/gold + sage green palette
 */
import ScrollReveal from '../../components/ScrollReveal.tsx';
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Vero Aesthetics | Subtle. Precise. You.</title>
  <meta name="description" content="Physician-led aesthetics on Park Avenue, Winter Park. Natural-looking results, no sales pressure." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display&family=DM+Sans:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    html { scroll-behavior: smooth; }
    body {
      font-family: 'DM Sans', sans-serif;
      background: #FAFAFA;
      color: #1A1A1A;
      -webkit-font-smoothing: antialiased;
      overflow-x: hidden;
    }
    img { max-width: 100%; display: block; }
    a { color: inherit; text-decoration: none; transition: color 0.3s ease; }

    /* ---------- Sticky glass nav ---------- */
    .nav {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      z-index: 100;
      padding: 1rem 2.5rem;
      display: flex;
      justify-content: space-between;
      align-items: center;
      transition: background 0.4s ease, box-shadow 0.4s ease, padding 0.4s ease;
    }
    .nav.scrolled {
      background: rgba(250, 250, 250, 0.75);
      backdrop-filter: blur(16px);
      -webkit-backdrop-filter: blur(16px);
      box-shadow: 0 1px 24px rgba(0,0,0,0.06);
      padding: 0.7rem 2.5rem;
    }
    .nav-brand {
      font-family: 'DM Serif Display', serif;
      font-size: 1.15rem;
      font-weight: 400;
      letter-spacing: 0.04em;
      color: #fff;
      transition: color 0.4s ease;
    }
    .nav.scrolled .nav-brand { color: #1A1A1A; }
    .nav-links {
      display: flex;
      gap: 2rem;
      list-style: none;
    }
    .nav-links a {
      font-size: 0.78rem;
      font-weight: 500;
      letter-spacing: 0.04em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.85);
      transition: color 0.3s ease;
    }
    .nav-links a:hover { color: #A3B18A; }
    .nav.scrolled .nav-links a { color: #777; }
    .nav.scrolled .nav-links a:hover { color: #A3B18A; }
    .nav-book {
      font-size: 0.72rem;
      font-weight: 600;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      padding: 0.55rem 1.4rem;
      border: 1px solid rgba(255,255,255,0.5);
      border-radius: 999px;
      color: #fff;
      transition: all 0.3s ease;
    }
    .nav-book:hover { background: #A3B18A; border-color: #A3B18A; color: #fff; }
    .nav.scrolled .nav-book { border-color: #1A1A1A; color: #1A1A1A; }
    .nav.scrolled .nav-book:hover { background: #A3B18A; border-color: #A3B18A; color: #fff; }

    /* ---------- Full-bleed serene hero ---------- */
    .hero {
      position: relative;
      width: 100%;
      height: 100vh;
      min-height: 600px;
      overflow: hidden;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .hero-bg {
      position: absolute;
      inset: 0;
      z-index: 0;
    }
    .hero-bg img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      filter: brightness(0.55) saturate(0.9);
    }
    .hero-overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(
        180deg,
        rgba(26,26,26,0.25) 0%,
        rgba(26,26,26,0.1) 40%,
        rgba(163,177,138,0.2) 100%
      );
      z-index: 1;
    }
    .hero-content {
      position: relative;
      z-index: 2;
      text-align: center;
      max-width: 700px;
      padding: 0 2rem;
    }
    .hero-eyebrow {
      font-size: 0.7rem;
      font-weight: 600;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: #A3B18A;
      margin-bottom: 1.5rem;
    }
    .hero h1 {
      font-family: 'DM Serif Display', serif;
      font-size: clamp(2.8rem, 6.5vw, 5rem);
      font-weight: 400;
      color: #fff;
      letter-spacing: -0.02em;
      line-height: 1.1;
      margin-bottom: 1.25rem;
    }
    .hero-sub {
      font-size: 1.05rem;
      color: rgba(255,255,255,0.8);
      line-height: 1.6;
      max-width: 480px;
      margin: 0 auto 2.5rem;
    }
    .hero-cta {
      display: inline-block;
      background: #A3B18A;
      color: #fff;
      padding: 0.9rem 2.4rem;
      border-radius: 999px;
      font-size: 0.8rem;
      font-weight: 600;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      transition: all 0.3s ease;
    }
    .hero-cta:hover {
      background: #8fa578;
      transform: translateY(-2px);
      box-shadow: 0 8px 28px rgba(163,177,138,0.35);
    }
    .hero-scroll {
      position: absolute;
      bottom: 2rem;
      left: 50%;
      transform: translateX(-50%);
      z-index: 2;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.5rem;
      color: rgba(255,255,255,0.5);
      font-size: 0.65rem;
      letter-spacing: 0.15em;
      text-transform: uppercase;
    }
    .hero-scroll-line {
      width: 1px;
      height: 40px;
      background: linear-gradient(180deg, rgba(255,255,255,0.5) 0%, transparent 100%);
      animation: scrollPulse 2s ease-in-out infinite;
    }
    @keyframes scrollPulse {
      0%, 100% { opacity: 0.3; transform: scaleY(0.6); }
      50% { opacity: 1; transform: scaleY(1); }
    }

    /* ---------- Shared section ---------- */
    .section {
      padding: 7rem 2rem;
      max-width: 1100px;
      margin: 0 auto;
    }
    .section-narrow { max-width: 700px; }
    .section-center { text-align: center; }
    .section h2 {
      font-family: 'DM Serif Display', serif;
      font-size: clamp(2rem, 4vw, 3rem);
      font-weight: 400;
      letter-spacing: -0.02em;
      margin-bottom: 0.75rem;
    }
    .section-eyebrow {
      font-size: 0.68rem;
      font-weight: 600;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: #A3B18A;
      margin-bottom: 1rem;
    }
    .section-desc {
      font-size: 0.95rem;
      color: #777;
      line-height: 1.7;
      max-width: 540px;
    }
    .section-center .section-desc { margin: 0 auto; }

    /* ---------- Intro strip ---------- */
    .intro-strip {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 2.5rem;
      margin-top: 3.5rem;
      text-align: center;
    }
    .intro-item h4 {
      font-family: 'DM Serif Display', serif;
      font-size: 1.05rem;
      font-weight: 400;
      margin-bottom: 0.5rem;
    }
    .intro-item p {
      font-size: 0.82rem;
      color: #888;
      line-height: 1.6;
    }
    .intro-divider {
      width: 32px;
      height: 2px;
      background: #A3B18A;
      margin: 0 auto 1rem;
      border-radius: 2px;
    }

    /* ---------- Image showcase ---------- */
    .showcase-band {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 0;
      max-width: 100%;
      overflow: hidden;
    }
    .showcase-cell {
      position: relative;
      height: 380px;
      overflow: hidden;
    }
    .showcase-cell img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform 0.6s ease;
    }
    .showcase-cell:hover img { transform: scale(1.04); }
    .showcase-cell-overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(180deg, transparent 50%, rgba(26,26,26,0.5) 100%);
      display: flex;
      align-items: flex-end;
      padding: 2rem;
    }
    .showcase-cell-label {
      font-family: 'DM Serif Display', serif;
      font-size: 1.1rem;
      color: #fff;
    }

    /* ---------- Treatment menu grid ---------- */
    .treatments-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 1.5rem;
      margin-top: 3rem;
    }
    .treatment-card {
      background: #fff;
      border-radius: 16px;
      padding: 2.25rem 2rem;
      border: 1px solid rgba(163,177,138,0.15);
      transition: border-color 0.3s ease, box-shadow 0.3s ease, transform 0.3s ease;
      position: relative;
      overflow: hidden;
    }
    .treatment-card::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 3px;
      background: linear-gradient(90deg, #A3B18A, #C9B458);
      opacity: 0;
      transition: opacity 0.3s ease;
    }
    .treatment-card:hover::before { opacity: 1; }
    .treatment-card:hover {
      border-color: #A3B18A;
      box-shadow: 0 12px 36px rgba(163,177,138,0.12);
      transform: translateY(-4px);
    }
    .treatment-card h3 {
      font-family: 'DM Serif Display', serif;
      font-size: 1.2rem;
      font-weight: 400;
      margin-bottom: 0.5rem;
    }
    .treatment-card p {
      font-size: 0.82rem;
      color: #777;
      line-height: 1.6;
      margin-bottom: 1rem;
    }
    .treatment-price {
      font-size: 0.9rem;
      font-weight: 600;
      color: #A3B18A;
      letter-spacing: 0.02em;
    }
    .treatment-price span {
      font-size: 0.72rem;
      font-weight: 400;
      color: #aaa;
    }

    /* ---------- Results showcase ---------- */
    .results-section {
      background: #1A1A1A;
      padding: 7rem 2rem;
      color: #fff;
    }
    .results-inner {
      max-width: 1100px;
      margin: 0 auto;
    }
    .results-section .section-eyebrow { color: #C9B458; }
    .results-section h2 { color: #fff; }
    .results-section .section-desc { color: rgba(255,255,255,0.55); margin: 0 auto; }
    .results-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 2rem;
      margin-top: 3.5rem;
    }
    .result-card {
      border-radius: 16px;
      overflow: hidden;
      background: rgba(255,255,255,0.04);
      border: 1px solid rgba(255,255,255,0.06);
      transition: transform 0.3s ease, border-color 0.3s ease;
    }
    .result-card:hover {
      transform: translateY(-4px);
      border-color: rgba(163,177,138,0.3);
    }
    .result-card-img {
      height: 220px;
      overflow: hidden;
    }
    .result-card-img img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform 0.5s ease;
    }
    .result-card:hover .result-card-img img { transform: scale(1.05); }
    .result-card-body {
      padding: 1.5rem;
    }
    .result-card-body h4 {
      font-family: 'DM Serif Display', serif;
      font-size: 1rem;
      font-weight: 400;
      margin-bottom: 0.4rem;
    }
    .result-card-body p {
      font-size: 0.78rem;
      color: rgba(255,255,255,0.45);
      line-height: 1.5;
    }
    .result-card-tag {
      display: inline-block;
      font-size: 0.6rem;
      font-weight: 600;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: #C9B458;
      margin-top: 0.75rem;
    }

    /* ---------- About Dr. Whitfield ---------- */
    .about-section {
      padding: 7rem 2rem;
      max-width: 900px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: 1fr 1.2fr;
      gap: 4rem;
      align-items: center;
    }
    .about-img {
      border-radius: 20px;
      overflow: hidden;
      height: 450px;
      position: relative;
    }
    .about-img img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }
    .about-img::after {
      content: '';
      position: absolute;
      inset: 0;
      border-radius: 20px;
      border: 1px solid rgba(163,177,138,0.2);
    }
    .about-text h2 {
      font-family: 'DM Serif Display', serif;
      font-size: 2.2rem;
      font-weight: 400;
      margin-bottom: 1.5rem;
    }
    .about-text p {
      font-size: 0.9rem;
      color: #666;
      line-height: 1.8;
      margin-bottom: 1rem;
    }
    .about-credentials {
      display: flex;
      gap: 1.5rem;
      margin-top: 1.5rem;
    }
    .credential {
      text-align: center;
    }
    .credential-num {
      font-family: 'DM Serif Display', serif;
      font-size: 1.8rem;
      color: #A3B18A;
    }
    .credential-label {
      font-size: 0.68rem;
      color: #999;
      text-transform: uppercase;
      letter-spacing: 0.08em;
    }

    /* ---------- Testimonials ---------- */
    .testimonials-section {
      background: linear-gradient(180deg, #F5F1EB 0%, #FAFAFA 100%);
      padding: 7rem 2rem;
    }
    .testimonials-inner {
      max-width: 900px;
      margin: 0 auto;
      text-align: center;
    }
    .testimonials-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 2rem;
      margin-top: 3rem;
      text-align: left;
    }
    .testimonial {
      background: #fff;
      border-radius: 16px;
      padding: 2rem;
      border: 1px solid rgba(163,177,138,0.12);
      transition: transform 0.3s ease, box-shadow 0.3s ease;
    }
    .testimonial:hover {
      transform: translateY(-3px);
      box-shadow: 0 10px 30px rgba(0,0,0,0.04);
    }
    .testimonial-stars {
      color: #C9B458;
      font-size: 0.85rem;
      margin-bottom: 1rem;
      letter-spacing: 0.1em;
    }
    .testimonial-quote {
      font-size: 0.92rem;
      color: #444;
      line-height: 1.65;
      margin-bottom: 1.25rem;
      font-style: italic;
    }
    .testimonial-author {
      display: flex;
      align-items: center;
      gap: 0.75rem;
    }
    .testimonial-avatar {
      width: 36px;
      height: 36px;
      border-radius: 50%;
      background: #A3B18A;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 0.75rem;
      font-weight: 600;
      color: #fff;
    }
    .testimonial-name {
      font-size: 0.82rem;
      font-weight: 600;
      color: #1A1A1A;
    }
    .testimonial-role {
      font-size: 0.7rem;
      color: #999;
    }

    /* ---------- Booking CTA ---------- */
    .booking-section {
      position: relative;
      overflow: hidden;
      padding: 8rem 2rem;
      text-align: center;
    }
    .booking-bg {
      position: absolute;
      inset: 0;
      z-index: 0;
    }
    .booking-bg img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      filter: brightness(0.35) saturate(0.8);
    }
    .booking-content {
      position: relative;
      z-index: 2;
      max-width: 600px;
      margin: 0 auto;
    }
    .booking-content .section-eyebrow { color: #C9B458; }
    .booking-content h2 {
      font-family: 'DM Serif Display', serif;
      font-size: clamp(2rem, 4vw, 3rem);
      color: #fff;
      font-weight: 400;
      margin-bottom: 1rem;
    }
    .booking-content p {
      font-size: 0.95rem;
      color: rgba(255,255,255,0.65);
      line-height: 1.7;
      margin-bottom: 2.5rem;
    }
    .booking-actions {
      display: flex;
      gap: 1rem;
      justify-content: center;
      flex-wrap: wrap;
    }
    .btn-primary {
      display: inline-block;
      background: #A3B18A;
      color: #fff;
      padding: 0.9rem 2.4rem;
      border-radius: 999px;
      font-size: 0.8rem;
      font-weight: 600;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      transition: all 0.3s ease;
    }
    .btn-primary:hover {
      background: #8fa578;
      transform: translateY(-2px);
      box-shadow: 0 8px 28px rgba(163,177,138,0.35);
    }
    .btn-outline {
      display: inline-block;
      color: #fff;
      padding: 0.9rem 2.4rem;
      border-radius: 999px;
      font-size: 0.8rem;
      font-weight: 600;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      border: 1px solid rgba(255,255,255,0.4);
      transition: all 0.3s ease;
    }
    .btn-outline:hover {
      background: rgba(255,255,255,0.1);
      border-color: #fff;
      transform: translateY(-2px);
    }

    /* ---------- AI section ---------- */
    .ai-section {
      padding: 5rem 2rem;
      text-align: center;
      max-width: 600px;
      margin: 0 auto;
    }
    .ai-icon {
      width: 48px;
      height: 48px;
      border-radius: 12px;
      background: linear-gradient(135deg, #A3B18A, #C9B458);
      margin: 0 auto 1.5rem;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .ai-icon svg { width: 22px; height: 22px; fill: #fff; }
    .ai-section h3 {
      font-family: 'DM Serif Display', serif;
      font-size: 1.4rem;
      font-weight: 400;
      margin-bottom: 0.75rem;
    }
    .ai-section p {
      font-size: 0.85rem;
      color: #888;
      line-height: 1.7;
    }
    .ai-badge {
      margin-top: 1.25rem;
      font-size: 0.58rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.12em;
      color: #ccc;
      transition: color 0.3s ease;
    }
    .ai-badge:hover { color: #A3B18A; }

    /* ---------- Footer ---------- */
    .footer {
      padding: 4rem 2rem 3rem;
      text-align: center;
      border-top: 1px solid #eee;
      background: #FAFAFA;
    }
    .footer-brand {
      font-family: 'DM Serif Display', serif;
      font-size: 1.1rem;
      font-weight: 400;
      margin-bottom: 1rem;
    }
    .footer p {
      font-size: 0.78rem;
      color: #999;
      line-height: 1.8;
    }
    .footer a {
      color: #A3B18A;
      transition: color 0.3s ease, opacity 0.3s ease;
    }
    .footer a:hover { opacity: 0.7; }
    .footer-links {
      display: flex;
      justify-content: center;
      gap: 2rem;
      margin-top: 1.5rem;
      margin-bottom: 1.5rem;
    }
    .footer-links a {
      font-size: 0.72rem;
      font-weight: 500;
      color: #999;
      text-transform: uppercase;
      letter-spacing: 0.08em;
    }
    .footer-links a:hover { color: #A3B18A; }

    /* ---------- Floating CTA badge ---------- */
    .cta-badge {
      position: fixed;
      bottom: 1rem;
      right: 1rem;
      z-index: 50;
      background: rgba(26,26,26,0.9);
      border: 1px solid #333;
      color: #A3B18A;
      padding: 0.5rem 1rem;
      border-radius: 999px;
      font-size: 0.7rem;
      backdrop-filter: blur(8px);
      transition: all 0.3s ease;
    }
    .cta-badge:hover { background: #A3B18A; color: #fff; border-color: #A3B18A; transform: translateY(-2px); }

    /* ---------- Mobile ---------- */
    @media (max-width: 768px) {
      .nav-links { display: none; }
      .hero { min-height: 500px; }
      .hero h1 { font-size: clamp(2.2rem, 8vw, 3.2rem); }
      .intro-strip { grid-template-columns: 1fr; gap: 2rem; }
      .showcase-band { grid-template-columns: 1fr; }
      .showcase-cell { height: 260px; }
      .treatments-grid { grid-template-columns: 1fr; }
      .results-grid { grid-template-columns: 1fr; }
      .about-section {
        grid-template-columns: 1fr;
        gap: 2rem;
        padding: 5rem 1.5rem;
      }
      .about-img { height: 300px; }
      .testimonials-grid { grid-template-columns: 1fr; }
      .booking-actions { flex-direction: column; align-items: center; }
    }
  </style>
</head>
<body>

  <!-- Sticky glass nav -->
  <nav class="nav" id="mainNav">
    <div class="nav-brand">Vero Aesthetics</div>
    <ul class="nav-links">
      <li><a href="#treatments">Treatments</a></li>
      <li><a href="#results">Results</a></li>
      <li><a href="#about">About</a></li>
      <li><a href="#testimonials">Reviews</a></li>
    </ul>
    <a href="#booking" class="nav-book">Book Now</a>
  </nav>

  <!-- Full-bleed serene hero -->
  <section class="hero">
    <div class="hero-bg">
      <img src="https://images.pexels.com/photos/3188/love-romantic-bath-candlelight.jpg?auto=compress&cs=tinysrgb&w=1920&h=1080&fit=crop" alt="Serene spa atmosphere" />
    </div>
    <div class="hero-overlay"></div>
    <div class="hero-content">
      <div class="hero-eyebrow">Park Avenue, Winter Park</div>
      <h1>Subtle. Precise. You.</h1>
      <p class="hero-sub">Physician-led aesthetics where natural results come first. No sales pressure, no package upsells. Just good work.</p>
      <a href="#booking" class="hero-cta">Free Consultation</a>
    </div>
    <div class="hero-scroll">
      <span>Scroll</span>
      <div class="hero-scroll-line"></div>
    </div>
  </section>

  <!-- Intro strip -->
  <ScrollReveal client:visible>
    <section class="section section-center" style="max-width: 900px;">
      <div class="section-eyebrow">Why Vero</div>
      <h2>Experience the Difference</h2>
      <p class="section-desc">Everything we offer is performed or overseen by Dr. Whitfield. You deserve that level of care.</p>
      <div class="intro-strip">
        <div class="intro-item">
          <div class="intro-divider"></div>
          <h4>Physician-Led</h4>
