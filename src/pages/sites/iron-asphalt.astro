---
/**
 * Iron & Asphalt Customs - SoDo, Orlando
 * VAULT template + Honda Motorcycles design language
 * Colors: #0D0D0D dark bg, #D4382C red accent, #D4A017 yellow, #2563EB blue
 */
import ScrollReveal from '../../components/ScrollReveal.tsx';
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Iron & Asphalt Customs | Built. Not Bought.</title>
  <meta name="description" content="Custom motorcycle builds, restorations, and performance tuning in SoDo, Orlando. Cafe racers, bobbers, scramblers -- all built in-house by Marco Reyes." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Oswald:wght@400;500;600;700&family=Barlow:wght@400;500;600&family=Playfair+Display:ital,wght@1,400;1,700&display=swap" rel="stylesheet" />
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    html { scroll-behavior: smooth; }
    body {
      font-family: 'Barlow', sans-serif;
      background: #0D0D0D;
      color: #E8E0D4;
      -webkit-font-smoothing: antialiased;
    }
    h1, h2, h3, h4 { font-family: 'Oswald', sans-serif; text-transform: uppercase; }
    img { max-width: 100%; display: block; }
    a { color: inherit; text-decoration: none; }

    /* ── Sticky Nav with glass effect ── */
    .nav {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      z-index: 100;
      background: rgba(13, 13, 13, 0.85);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      padding: 0 2rem;
      height: 64px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      border-bottom: 1px solid rgba(255,255,255,0.05);
      transition: background 0.3s, box-shadow 0.3s;
    }
    .nav.scrolled {
      background: rgba(13, 13, 13, 0.95);
      box-shadow: 0 2px 24px rgba(0,0,0,0.5);
    }
    .nav-left {
      display: flex;
      align-items: center;
      gap: 0.75rem;
    }
    .nav-icon {
      width: 36px;
      height: 36px;
      background: #D4382C;
      border-radius: 4px;
      display: flex;
      align-items: center;
      justify-content: center;
      color: #fff;
      font-family: 'Oswald', sans-serif;
      font-size: 0.7rem;
      font-weight: 700;
      letter-spacing: 0.02em;
    }
    .nav-brand {
      font-family: 'Oswald', sans-serif;
      font-size: 1rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      color: #fff;
    }
    .nav-links {
      display: flex;
      gap: 2rem;
      align-items: center;
    }
    .nav-links a {
      font-family: 'Oswald', sans-serif;
      font-size: 0.7rem;
      font-weight: 500;
      text-transform: uppercase;
      letter-spacing: 0.12em;
      color: #888;
      transition: color 0.2s;
      position: relative;
    }
    .nav-links a:hover { color: #fff; }
    .nav-links a::after {
      content: '';
      position: absolute;
      bottom: -4px;
      left: 0;
      right: 0;
      height: 2px;
      background: #D4382C;
      transform: scaleX(0);
      transition: transform 0.3s;
    }
    .nav-links a:hover::after { transform: scaleX(1); }
    .nav-cta {
      background: #D4382C;
      color: #fff !important;
      padding: 0.45rem 1.2rem;
      border-radius: 2px;
      font-weight: 600;
      transition: background 0.2s, transform 0.2s;
    }
    .nav-cta:hover { background: #b82e24; transform: translateY(-1px); }
    .nav-cta::after { display: none !important; }
    .nav-spacer { height: 64px; }

    /* ── Full-bleed hero ── */
    .hero {
      position: relative;
      height: 90vh;
      min-height: 550px;
      max-height: 900px;
      overflow: hidden;
    }
    .hero-img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: center 40%;
      filter: brightness(0.45) contrast(1.15);
    }
    .hero-overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(
        180deg,
        rgba(13,13,13,0.3) 0%,
        rgba(13,13,13,0.1) 40%,
        rgba(13,13,13,0.6) 75%,
        rgba(13,13,13,1) 100%
      );
    }
    .hero-content {
      position: absolute;
      bottom: 0;
      left: 0;
      right: 0;
      padding: 4rem 2rem 3rem;
      max-width: 1100px;
      margin: 0 auto;
    }
    .hero-tag {
      font-family: 'Oswald', sans-serif;
      font-size: 0.65rem;
      text-transform: uppercase;
      letter-spacing: 0.2em;
      color: #D4382C;
      margin-bottom: 1rem;
      display: flex;
      align-items: center;
      gap: 0.75rem;
    }
    .hero-tag::before {
      content: '';
      width: 32px;
      height: 2px;
      background: #D4382C;
    }
    .hero h1 {
      font-size: clamp(3.5rem, 10vw, 7rem);
      font-weight: 700;
      line-height: 0.9;
      color: #fff;
      letter-spacing: -0.02em;
      margin-bottom: 1.25rem;
    }
    .hero-sub {
      font-size: 1.05rem;
      color: rgba(255,255,255,0.65);
      line-height: 1.6;
      max-width: 520px;
      margin-bottom: 2rem;
    }
    .hero-cta {
      display: inline-flex;
      align-items: center;
      gap: 0.75rem;
      background: #D4382C;
      color: #fff;
      padding: 0.85rem 2.2rem;
      font-family: 'Oswald', sans-serif;
      font-size: 0.8rem;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      font-weight: 600;
      border: none;
      cursor: pointer;
      transition: background 0.2s, transform 0.2s;
    }
    .hero-cta:hover { background: #b82e24; transform: translateY(-2px); }
    .hero-cta svg { width: 16px; height: 16px; }

    /* ── Accent bars ── */
    .accent-bar-yellow {
      background: #D4A017;
      padding: 1.25rem 2rem;
      display: flex;
      align-items: center;
      gap: 1rem;
    }
    .accent-bar-yellow h2 {
      font-family: 'Oswald', sans-serif;
      font-size: 0.7rem;
      text-transform: uppercase;
      letter-spacing: 0.2em;
      color: #000;
      margin: 0;
    }
    .accent-bar-yellow span {
      font-size: 0.65rem;
      color: rgba(0,0,0,0.6);
      letter-spacing: 0.05em;
    }
    .accent-bar-blue {
      background: #2563EB;
      padding: 0.5rem 2rem;
      text-align: right;
    }
    .accent-bar-blue span {
      font-family: 'Oswald', sans-serif;
      font-size: 0.6rem;
      text-transform: uppercase;
      letter-spacing: 0.15em;
      color: #fff;
    }

    /* ── Our Builds showcase grid ── */
    .builds-section {
      padding: 5rem 2rem;
      max-width: 1100px;
      margin: 0 auto;
    }
    .section-header {
      margin-bottom: 3rem;
    }
    .section-header .label {
      font-family: 'Oswald', sans-serif;
      font-size: 0.65rem;
      text-transform: uppercase;
      letter-spacing: 0.2em;
      color: #D4382C;
      margin-bottom: 0.75rem;
      display: flex;
      align-items: center;
      gap: 0.75rem;
    }
    .section-header .label::before {
      content: '';
      width: 24px;
      height: 2px;
      background: #D4382C;
    }
    .section-header h2 {
      font-family: 'Playfair Display', serif;
      font-style: italic;
      text-transform: none;
      font-size: clamp(2rem, 5vw, 3rem);
      font-weight: 400;
      color: #fff;
    }
    .builds-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1.5rem;
    }
    .build-card {
      background: #141414;
      border-radius: 4px;
      overflow: hidden;
      border: 1px solid #1e1e1e;
      transition: border-color 0.3s, transform 0.3s;
    }
    .build-card:hover {
      border-color: #D4382C;
      transform: translateY(-4px);
    }
    .build-card-img {
      position: relative;
      overflow: hidden;
      aspect-ratio: 16/10;
    }
    .build-card-img img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform 0.5s;
    }
    .build-card:hover .build-card-img img { transform: scale(1.06); }
    .build-card-img .badge {
      position: absolute;
      top: 1rem;
      left: 1rem;
      background: rgba(212,56,44,0.9);
      color: #fff;
      font-family: 'Oswald', sans-serif;
      font-size: 0.55rem;
      text-transform: uppercase;
      letter-spacing: 0.12em;
      padding: 0.3rem 0.75rem;
      border-radius: 2px;
    }
    .build-card-body {
      padding: 1.5rem;
    }
    .build-card-body h3 {
      font-size: 1.1rem;
      font-weight: 600;
      color: #fff;
      letter-spacing: 0.04em;
      margin-bottom: 0.5rem;
    }
    .build-card-body p {
      font-size: 0.8rem;
      color: #777;
      line-height: 1.7;
      margin-bottom: 1rem;
    }
    .build-card-link {
      font-family: 'Oswald', sans-serif;
      font-size: 0.7rem;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: #D4382C;
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      transition: gap 0.2s;
    }
    .build-card:hover .build-card-link { gap: 0.75rem; }

    /* ── Icon/Feature row ── */
    .features-bar {
      background: #111;
      border-top: 1px solid #1e1e1e;
      border-bottom: 1px solid #1e1e1e;
      padding: 3.5rem 2rem;
    }
    .features-inner {
      max-width: 1100px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 2rem;
    }
    .feature-item {
      text-align: center;
    }
    .feature-icon {
      width: 56px;
      height: 56px;
      margin: 0 auto 1rem;
      background: rgba(212,56,44,0.1);
      border: 1px solid rgba(212,56,44,0.2);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .feature-icon svg {
      width: 24px;
      height: 24px;
      stroke: #D4382C;
      fill: none;
      stroke-width: 1.5;
      stroke-linecap: round;
      stroke-linejoin: round;
    }
    .feature-item h4 {
      font-size: 0.75rem;
      font-weight: 600;
      color: #fff;
      letter-spacing: 0.08em;
      margin-bottom: 0.35rem;
    }
    .feature-item p {
      font-size: 0.7rem;
      color: #666;
      line-height: 1.5;
    }

    /* ── Services grid (Honda category browser style) ── */
    .services-section {
      padding: 5rem 2rem;
      max-width: 1100px;
      margin: 0 auto;
    }
    .services-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 1.25rem;
    }
    .service-card {
      background: #141414;
      border: 1px solid #1e1e1e;
      border-radius: 4px;
      padding: 2rem;
      display: flex;
      gap: 1.5rem;
      align-items: flex-start;
      transition: border-color 0.3s, background 0.3s;
    }
    .service-card:hover {
      border-color: #333;
      background: #1a1a1a;
    }
    .service-icon {
      flex-shrink: 0;
      width: 44px;
      height: 44px;
      background: #D4382C;
      border-radius: 4px;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .service-icon svg {
      width: 22px;
      height: 22px;
      stroke: #fff;
      fill: none;
      stroke-width: 1.5;
      stroke-linecap: round;
      stroke-linejoin: round;
    }
    .service-info h3 {
      font-size: 0.85rem;
      font-weight: 600;
      color: #fff;
      letter-spacing: 0.05em;
      margin-bottom: 0.5rem;
    }
    .service-info p {
      font-size: 0.8rem;
      color: #777;
      line-height: 1.7;
    }
    .service-info ul {
      list-style: none;
      margin-top: 0.75rem;
    }
    .service-info ul li {
      font-size: 0.75rem;
      color: #666;
      line-height: 1.9;
      padding-left: 1rem;
      position: relative;
    }
    .service-info ul li::before {
      content: '';
      position: absolute;
      left: 0;
      top: 0.55em;
      width: 4px;
      height: 4px;
      background: #D4382C;
      border-radius: 50%;
    }

    /* ── Gallery row ── */
    .gallery-row {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 3px;
    }
    .gallery-cell {
      position: relative;
      overflow: hidden;
    }
    .gallery-cell img {
      width: 100%;
      aspect-ratio: 1;
      object-fit: cover;
      filter: grayscale(30%) contrast(1.1);
      transition: filter 0.5s, transform 0.5s;
    }
    .gallery-cell:hover img {
      filter: grayscale(0%) contrast(1.05);
      transform: scale(1.05);
    }
    .gallery-cell-overlay {
      position: absolute;
      inset: 0;
      background: rgba(212, 56, 44, 0);
      display: flex;
      align-items: center;
      justify-content: center;
      transition: background 0.3s;
    }
    .gallery-cell:hover .gallery-cell-overlay {
      background: rgba(212, 56, 44, 0.12);
    }

    /* ── Marquee ── */
    .marquee {
      background: #D4382C;
      padding: 0.75rem 0;
      overflow: hidden;
      white-space: nowrap;
    }
    .marquee-inner {
      display: inline-block;
      animation: scroll-left 20s linear infinite;
    }
    .marquee-text {
      font-family: 'Oswald', sans-serif;
      font-size: 0.8rem;
      text-transform: uppercase;
      letter-spacing: 0.15em;
      color: #fff;
    }
    .marquee-text span { margin: 0 2rem; opacity: 0.5; }
    @keyframes scroll-left {
      0% { transform: translateX(0); }
      100% { transform: translateX(-50%); }
    }

    /* ── Quote CTA section ── */
    .quote-section {
      background: linear-gradient(135deg, #1a1a1a 0%, #111 100%);
      padding: 5rem 2rem;
      text-align: center;
    }
    .quote-section h2 {
      font-family: 'Playfair Display', serif;
      font-style: italic;
      text-transform: none;
      font-size: clamp(1.8rem, 4vw, 2.5rem);
      color: #fff;
      margin-bottom: 0.75rem;
    }
    .quote-section p {
      font-size: 0.85rem;
      color: #888;
      margin-bottom: 2rem;
      max-width: 480px;
      margin-left: auto;
      margin-right: auto;
      line-height: 1.7;
    }
    .quote-cta {
      display: inline-flex;
      align-items: center;
      gap: 0.75rem;
      background: #D4382C;
      color: #fff;
      padding: 0.85rem 2.5rem;
      font-family: 'Oswald', sans-serif;
      font-size: 0.8rem;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      font-weight: 600;
      transition: background 0.2s, transform 0.2s;
    }
    .quote-cta:hover { background: #b82e24; transform: translateY(-2px); }

    /* ── Testimonials ── */
    .testimonials {
      padding: 5rem 2rem;
      max-width: 1100px;
      margin: 0 auto;
    }
    .testimonial-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1.5rem;
    }
    .testimonial-card {
      background: #141414;
      border-left: 3px solid #D4382C;
      padding: 2rem;
      border-radius: 0 4px 4px 0;
    }
    .testimonial-card blockquote {
      font-size: 0.85rem;
      color: #ccc;
      line-height: 1.8;
      font-style: italic;
      margin-bottom: 1.25rem;
    }
    .testimonial-card cite {
      font-style: normal;
      font-size: 0.7rem;
      color: #666;
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }
    .testimonial-card cite strong {
      color: #fff;
      display: block;
      margin-bottom: 0.15rem;
    }

    /* ── About Marco ── */
    .about-section {
      background: #1A1A1A;
      padding: 5rem 2rem;
    }
    .about-inner {
      max-width: 1100px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 4rem;
      align-items: center;
    }
    .about-text p {
      font-size: 0.9rem;
      color: #999;
      line-height: 1.9;
      margin-bottom: 1.25rem;
    }
    .about-text .owner {
      margin-top: 2rem;
      padding-top: 1.5rem;
      border-top: 1px solid #333;
    }
    .about-text .owner strong {
      font-family: 'Oswald', sans-serif;
      font-size: 1rem;
      color: #fff;
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }
    .about-text .owner span {
      color: #666;
      display: block;
      font-size: 0.75rem;
      margin-top: 0.25rem;
    }
    .about-image {
      border-radius: 4px;
      overflow: hidden;
      position: relative;
    }
    .about-image img {
      width: 100%;
      aspect-ratio: 4/3;
      object-fit: cover;
      filter: contrast(1.1);
    }
    .about-image::after {
      content: '';
      position: absolute;
      bottom: 0;
      left: 0;
      right: 0;
      height: 40%;
      background: linear-gradient(to top, rgba(26,26,26,0.5), transparent);
    }

    /* ── AI section ── */
    .ai-section {
      padding: 4rem 2rem;
      text-align: center;
      max-width: 600px;
      margin: 0 auto;
    }
    .ai-section h3 {
      font-family: 'Oswald', sans-serif;
      font-size: 0.9rem;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: #fff;
      margin-bottom: 0.75rem;
    }
    .ai-section p {
      font-size: 0.8rem;
      color: #666;
      line-height: 1.8;
    }
    .ai-badge {
      margin-top: 1.25rem;
      font-size: 0.55rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.12em;
      color: #444;
    }

    /* ── Footer (dark with red accents, Honda-style) ── */
    .footer {
      background: #0a0a0a;
      border-top: 3px solid #D4382C;
      padding: 4rem 2rem 2rem;
    }
    .footer-inner {
      max-width: 1100px;
      margin: 0 auto;
    }
    .footer-top {
      display: grid;
      grid-template-columns: 2fr 1fr 1fr;
      gap: 3rem;
      margin-bottom: 3rem;
    }
    .footer-brand-block .footer-brand {
      font-family: 'Oswald', sans-serif;
      font-size: 1.5rem;
      font-weight: 700;
      text-transform: uppercase;
      color: #fff;
      letter-spacing: 0.02em;
      margin-bottom: 1rem;
    }
    .footer-brand-block p {
      font-size: 0.75rem;
      color: #555;
      line-height: 1.8;
      max-width: 320px;
    }
    .footer-col h4 {
      font-size: 0.65rem;
      letter-spacing: 0.15em;
      color: #D4382C;
      margin-bottom: 1rem;
    }
    .footer-col a {
      display: block;
      font-size: 0.75rem;
      color: #666;
      line-height: 2.2;
      transition: color 0.2s;
    }
    .footer-col a:hover { color: #fff; }
    .footer-bottom {
      border-top: 1px solid #1e1e1e;
      padding-top: 1.5rem;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
    .footer-bottom p {
      font-size: 0.65rem;
      color: #444;
    }
    .footer-bottom a { color: #D4382C; }
    .footer-bottom a:hover { text-decoration: underline; }

    /* ── CTA badge ── */
    .cta-badge {
      position: fixed;
      bottom: 1.25rem;
      right: 1.25rem;
      z-index: 50;
      background: rgba(13,13,13,0.92);
      border: 1px solid #333;
      color: #E8E0D4;
      padding: 0.5rem 1rem;
      border-radius: 999px;
      font-size: 0.7rem;
      backdrop-filter: blur(8px);
      transition: all 0.2s;
    }
    .cta-badge:hover { background: #D4382C; border-color: #D4382C; }

    /* ── Mobile hamburger ── */
    .nav-toggle {
      display: none;
      background: none;
      border: none;
      cursor: pointer;
      padding: 0.5rem;
    }
    .nav-toggle span {
      display: block;
      width: 20px;
      height: 2px;
      background: #fff;
      margin: 4px 0;
      transition: transform 0.3s, opacity 0.3s;
    }

    /* ── Responsive ── */
    @media (max-width: 1024px) {
      .builds-grid { grid-template-columns: repeat(2, 1fr); }
      .footer-top { grid-template-columns: 1fr 1fr; }
    }
    @media (max-width: 768px) {
      .nav-links {
        display: none;
        position: absolute;
        top: 64px;
        left: 0;
        right: 0;
        background: rgba(13,13,13,0.97);
        backdrop-filter: blur(12px);
        flex-direction: column;
        padding: 1.5rem 2rem;
        gap: 1rem;
        border-bottom: 1px solid #222;
      }
      .nav-links.open { display: flex; }
      .nav-toggle { display: block; }
      .hero { height: 70vh; min-height: 420px; }
      .hero h1 { font-size: clamp(2.5rem, 12vw, 4.5rem); }
      .builds-grid { grid-template-columns: 1fr; }
      .features-inner { grid-template-columns: repeat(2, 1fr); gap: 1.5rem; }
      .services-grid { grid-template-columns: 1fr; }
      .gallery-row { grid-template-columns: repeat(2, 1fr); }
      .about-inner { grid-template-columns: 1fr; gap: 2rem; }
