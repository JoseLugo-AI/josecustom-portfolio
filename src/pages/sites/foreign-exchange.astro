---
/**
 * Foreign Exchange Orlando - Mills 50, Orlando
 * Matched to: oasis-loop / NONSENSE template (pure white bg, HUGE centered bold black sans type,
 * ultra sparse/minimal, centered info blocks with labels, massive whitespace, manifesto at bottom)
 * Colors: black on white, ultra-minimal, orange accent
 */
import ScrollReveal from '../../components/ScrollReveal.tsx';
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Foreign Exchange | Curated. Not Mass-Produced.</title>
  <meta name="description" content="Independent streetwear, vintage sneakers, and local artist collabs on Mills Ave, Orlando." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=DM+Sans:wght@400;500&display=swap" rel="stylesheet" />
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    html { scroll-behavior: smooth; }
    body {
      font-family: 'DM Sans', sans-serif;
      background: #fff;
      color: #0A0A0A;
      -webkit-font-smoothing: antialiased;
    }
    img { max-width: 100%; display: block; }
    a { color: inherit; text-decoration: none; }

    /* ── Nav - ABOUT left, DIRECTIONS right ── */
    .nav {
      padding: 1.5rem 2rem;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
    .nav a {
      font-family: 'Space Grotesk', sans-serif;
      font-size: 0.65rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.12em;
      color: #0A0A0A;
      transition: color 0.2s;
    }
    .nav a:hover { color: #FF4D00; }

    /* ── Hero - HUGE centered brand name ── */
    .hero {
      text-align: center;
      padding: 2rem 2rem 1rem;
    }
    .hero h1 {
      font-family: 'Space Grotesk', sans-serif;
      font-size: clamp(3.5rem, 12vw, 8rem);
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: -0.03em;
      line-height: 0.95;
      color: #0A0A0A;
    }
    .hero-sub {
      margin-top: 1rem;
      display: flex;
      justify-content: space-between;
      align-items: center;
      max-width: 600px;
      margin-left: auto;
      margin-right: auto;
    }
    .hero-sub span {
      font-size: 0.6rem;
      font-weight: 500;
      color: #999;
      letter-spacing: 0.05em;
    }

    /* ── 3-column info row with vertical dividers ── */
    .info-row {
      display: grid;
      grid-template-columns: 1fr 1fr 1fr;
      max-width: 700px;
      margin: 3rem auto 0;
      padding: 0 2rem;
    }
    .info-cell {
      text-align: center;
      padding: 1.5rem 1rem;
      border-left: 1px solid #E5E5E5;
    }
    .info-cell:first-child { border-left: none; }
    .info-cell .label {
      font-family: 'Space Grotesk', sans-serif;
      font-size: 0.55rem;
      font-weight: 500;
      text-transform: uppercase;
      letter-spacing: 0.15em;
      color: #999;
      margin-bottom: 0.6rem;
    }
    .info-cell .value {
      font-family: 'Space Grotesk', sans-serif;
      font-size: clamp(0.8rem, 1.8vw, 1rem);
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: -0.01em;
      color: #0A0A0A;
      line-height: 1.4;
    }

    /* ── Massive whitespace ── */
    .spacer { height: 10rem; }
    .spacer-lg { height: 16rem; }
    .spacer-sm { height: 5rem; }

    /* ── Gallery - sparse grid with hover ── */
    .gallery {
      max-width: 900px;
      margin: 0 auto;
      padding: 0 2rem;
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 3px;
    }
    .gallery-item {
      position: relative;
      overflow: hidden;
    }
    .gallery-item img {
      width: 100%;
      aspect-ratio: 1;
      object-fit: cover;
      transition: transform 0.5s ease, filter 0.5s ease;
    }
    .gallery-item:hover img {
      transform: scale(1.05);
    }
    .gallery-label {
      position: absolute;
      inset: 0;
      display: flex;
      align-items: center;
      justify-content: center;
      background: rgba(10, 10, 10, 0);
      transition: background 0.3s;
    }
    .gallery-label span {
      font-family: 'Space Grotesk', sans-serif;
      font-size: 0.65rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: #fff;
      opacity: 0;
      transform: translateY(8px);
      transition: all 0.3s ease;
    }
    .gallery-item:hover .gallery-label {
      background: rgba(10, 10, 10, 0.45);
    }
    .gallery-item:hover .gallery-label span {
      opacity: 1;
      transform: translateY(0);
    }

    /* ── Manifesto - big bold text ── */
    .manifesto {
      max-width: 800px;
      margin: 0 auto;
      padding: 6rem 2rem;
    }
    .manifesto p {
      font-family: 'Space Grotesk', sans-serif;
      font-size: clamp(1.2rem, 3vw, 1.8rem);
      font-weight: 700;
      line-height: 1.4;
      color: #0A0A0A;
    }

    /* ── Services - minimal text blocks ── */
    .services-section {
      max-width: 600px;
      margin: 0 auto;
      padding: 0 2rem;
    }
    .service-item {
      padding: 1.5rem 0;
      border-top: 1px solid #E5E5E5;
      text-align: center;
    }
    .service-item:last-child {
      border-bottom: 1px solid #E5E5E5;
    }
    .service-item h3 {
      font-family: 'Space Grotesk', sans-serif;
      font-size: 0.85rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.02em;
      margin-bottom: 0.4rem;
    }
    .service-item p {
      font-size: 0.75rem;
      color: #888;
      line-height: 1.6;
      max-width: 400px;
      margin: 0 auto;
    }

    /* ── Newsletter CTA - outlined button ── */
    .newsletter {
      text-align: center;
      padding: 2rem;
    }
    .newsletter-btn {
      display: inline-block;
      border: 2px solid #0A0A0A;
      padding: 0.9rem 2.5rem;
      font-family: 'Space Grotesk', sans-serif;
      font-size: 0.7rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      transition: all 0.2s;
    }
    .newsletter-btn:hover {
      background: #0A0A0A;
      color: #fff;
    }

    /* ── AI section ── */
    .ai-section {
      text-align: center;
      padding: 3rem 2rem;
      max-width: 500px;
      margin: 0 auto;
    }
    .ai-section .label {
      font-family: 'Space Grotesk', sans-serif;
      font-size: 0.55rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.15em;
      color: #999;
      margin-bottom: 0.5rem;
    }
    .ai-section h3 {
      font-family: 'Space Grotesk', sans-serif;
      font-size: 0.9rem;
      font-weight: 700;
      text-transform: uppercase;
      margin-bottom: 0.5rem;
    }
    .ai-section p {
      font-size: 0.75rem;
      color: #888;
      line-height: 1.7;
    }
    .ai-badge {
      margin-top: 1rem;
      font-size: 0.5rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.12em;
      color: #ccc;
    }

    /* ── Footer - brand name repeated large, copyright left, social right ── */
    .footer {
      text-align: center;
      padding: 4rem 2rem 1.5rem;
    }
    .footer-label {
      font-size: 0.55rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.15em;
      color: #999;
      margin-bottom: 0.75rem;
    }
    .footer-brand {
      font-family: 'Space Grotesk', sans-serif;
      font-size: clamp(2rem, 8vw, 4rem);
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: -0.03em;
      color: #0A0A0A;
      margin-bottom: 1rem;
    }
    .footer-info {
      font-size: 0.65rem;
      color: #999;
      line-height: 1.8;
      margin-bottom: 1.5rem;
    }
    .footer-info a { color: #0A0A0A; font-weight: 500; }
    .footer-info a:hover { color: #FF4D00; }
    .footer-bottom {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 1rem 0;
      border-top: 1px solid #E5E5E5;
      font-size: 0.55rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: #999;
    }
    .footer-bottom a { color: #999; transition: color 0.2s; }
    .footer-bottom a:hover { color: #FF4D00; }

    /* ── Floating CTA badge ── */
    .cta-badge {
      position: fixed;
      bottom: 1rem;
      right: 1rem;
      z-index: 50;
      background: rgba(10,10,10,0.9);
      border: 1px solid #333;
      color: #fff;
      padding: 0.5rem 1rem;
      border-radius: 999px;
      font-size: 0.7rem;
      backdrop-filter: blur(8px);
      transition: all 0.2s;
    }
    .cta-badge:hover { background: #FF4D00; border-color: #FF4D00; }

    /* ── Text scramble animation ── */
    @keyframes glitch-in {
      0% { opacity: 0; transform: translateY(20px) skewX(-5deg); filter: blur(4px); }
      60% { opacity: 1; transform: translateY(-3px) skewX(1deg); filter: blur(0); }
      100% { opacity: 1; transform: translateY(0) skewX(0); }
    }
    .hero h1 {
      animation: glitch-in 0.8s cubic-bezier(0.16, 1, 0.3, 1) both;
    }
    .hero-sub {
      animation: glitch-in 0.8s cubic-bezier(0.16, 1, 0.3, 1) 0.15s both;
    }

    /* ── Responsive ── */
    @media (max-width: 768px) {
      .info-row { grid-template-columns: 1fr; gap: 0; }
      .info-cell { border-left: none; border-bottom: 1px solid #E5E5E5; padding: 1.2rem 0; }
      .info-cell:last-child { border-bottom: none; }
      .gallery { grid-template-columns: repeat(2, 1fr); }
      .spacer { height: 5rem; }
      .spacer-lg { height: 8rem; }
      .hero-sub { flex-direction: column; gap: 0.25rem; }
      .footer-bottom { flex-direction: column; gap: 0.5rem; }
    }
  </style>
</head>
<body>

  <nav class="nav">
    <a href="#about">About</a>
    <a href="#contact">Directions</a>
  </nav>

  <!-- Hero - HUGE brand name -->
  <section class="hero">
    <h1>Foreign<br />Exchange</h1>
    <div class="hero-sub">
      <span>A Mills 50 streetwear collective</span>
      <span>@foreignexchangeorl</span>
    </div>
  </section>

  <!-- 3-column info row like NONSENSE -->
  <ScrollReveal client:load>
    <div class="info-row">
      <div class="info-cell">
        <div class="label">What</div>
        <div class="value">Curated Streetwear<br />&amp; Vintage Sneakers</div>
      </div>
      <div class="info-cell">
        <div class="label">When</div>
        <div class="value">Tue-Sat 11am-7pm<br />Sun 12-5</div>
      </div>
      <div class="info-cell">
        <div class="label">Where</div>
        <div class="value">1608 N Mills Ave,<br />Orlando, FL 32803</div>
      </div>
    </div>
  </ScrollReveal>

  <div class="spacer-lg"></div>

  <!-- Gallery with hover labels -->
  <ScrollReveal client:load>
    <div class="gallery">
      <div class="gallery-item">
        <img src="https://images.unsplash.com/photo-1556906781-9a412961c28c?w=600&q=80" alt="Sneaker wall display" loading="lazy" />
        <div class="gallery-label"><span>Kicks</span></div>
      </div>
      <div class="gallery-item">
        <img src="https://images.unsplash.com/photo-1489987707025-afc232f7ea0f?w=600&q=80" alt="Clothing rack with streetwear" loading="lazy" />
        <div class="gallery-label"><span>Streetwear</span></div>
      </div>
      <div class="gallery-item">
        <img src="https://images.unsplash.com/photo-1558171813-4c088753af8f?w=600&q=80" alt="Store interior" loading="lazy" />
        <div class="gallery-label"><span>The Shop</span></div>
      </div>
      <div class="gallery-item">
        <img src="https://images.unsplash.com/photo-1523381210434-271e8be1f52b?w=600&q=80" alt="Curated accessories" loading="lazy" />
        <div class="gallery-label"><span>Accessories</span></div>
      </div>
      <div class="gallery-item">
        <img src="https://images.unsplash.com/photo-1460353581641-37baddab0fa2?w=600&q=80" alt="Vintage sneaker detail" loading="lazy" />
        <div class="gallery-label"><span>Deadstock</span></div>
      </div>
      <div class="gallery-item">
        <img src="https://images.unsplash.com/photo-1509631179647-0177331693ae?w=600&q=80" alt="Local collab t-shirt" loading="lazy" />
        <div class="gallery-label"><span>Collabs</span></div>
      </div>
    </div>
  </ScrollReveal>

  <div class="spacer-lg"></div>

  <!-- Manifesto -->
  <ScrollReveal client:load>
    <section id="about" class="manifesto">
      <p>Foreign Exchange is a rebellion against mass production. No trends, no fast fashion -- just curated streetwear, authenticated kicks, and collabs with Orlando artists.</p>
    </section>
  </ScrollReveal>

  <div class="spacer-sm"></div>

  <!-- Services -->
  <ScrollReveal client:load>
    <section class="services-section">
      <div class="service-item">
        <h3>Curated Streetwear</h3>
        <p>Independent and international brands you won't find at the mall. Small-run Japanese labels, independent UK designers, and emerging domestic brands.</p>
      </div>
      <div class="service-item">
        <h3>Vintage & Deadstock Sneakers</h3>
        <p>Authenticated pre-owned and deadstock kicks. We verify everything in-house. No fakes, no exceptions.</p>
      </div>
      <div class="service-item">
        <h3>Local Artist Collabs</h3>
        <p>Limited releases designed with Orlando artists. Screen-printed tees, embroidered caps, and one-off pieces you can only get here.</p>
      </div>
      <div class="service-item">
        <h3>Online Shop</h3>
        <p>Full catalog online with flat-rate shipping. New drops announced on Instagram before they hit the floor.</p>
      </div>
    </section>
  </ScrollReveal>

  <div class="spacer"></div>

  <!-- Newsletter CTA -->
  <ScrollReveal client:load>
    <section class="newsletter">
      <a href="mailto:shop@foreignexchangeorl.com" class="newsletter-btn">Sign Up for Drop Alerts</a>
    </section>
  </ScrollReveal>

  <div class="spacer-sm"></div>

  <!-- AI Section -->
  <ScrollReveal client:load>
    <section class="ai-section">
      <div class="label">Powered by AI</div>
      <h3>Style Recs & Drop Alerts</h3>
      <p>Our system learns what you like based on past purchases and browsing, then sends personalized alerts when new drops match your style. No spam, no generic newsletters -- just the pieces you'd actually want.</p>
      <div class="ai-badge">AI-Ready Architecture by josecustom.ai</div>
    </section>
  </ScrollReveal>

  <div class="spacer"></div>

  <!-- Footer - brand repeated large, bottom row split -->
  <footer id="contact" class="footer">
    <div class="footer-label">A streetwear collective</div>
    <div class="footer-brand">Foreign Exchange</div>
    <div class="footer-info">
      1608 N Mills Ave, Orlando, FL 32803<br />
      (407) 555-2156 &middot; <a href="mailto:shop@foreignexchangeorl.com">shop@foreignexchangeorl.com</a>
    </div>
    <div class="footer-bottom">
      <span>&copy; 2026 Foreign Exchange Orlando &middot; <a href="https://josecustom.ai/websites" target="_blank" rel="noopener">Built by josecustom.ai</a></span>
      <a href="#">@foreignexchangeorl</a>
    </div>
  </footer>

  <a href="https://josecustom.ai/websites" target="_blank" rel="noopener" class="cta-badge">Demo site by josecustom.ai</a>

</body>
</html>
