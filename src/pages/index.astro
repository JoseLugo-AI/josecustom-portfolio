---
import { PortfolioGallery } from '../components/PortfolioGallery.tsx';
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Portfolio | josecustom.ai</title>
    <meta name="description" content="AI-Ready websites built for Orlando businesses by josecustom.ai" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;500;600;700;800;900&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <style>
      * { margin: 0; padding: 0; box-sizing: border-box; }
      html, body {
        height: 100%;
        overflow: hidden;
        overscroll-behavior: none;
      }
      body {
        font-family: 'Inter', sans-serif;
        background: #0a0a0a;
        color: #fff;
        -webkit-font-smoothing: antialiased;
      }
      a { color: inherit; text-decoration: none; }

      @keyframes bounce-down {
        0%, 100% { transform: translateY(0); }
        50% { transform: translateY(6px); }
      }
    </style>
  </head>
  <body>
    <PortfolioGallery client:load />
  </body>
</html>
