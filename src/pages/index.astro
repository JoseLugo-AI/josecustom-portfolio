---
import { PortfolioGallery } from '../components/PortfolioGallery.tsx';
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Portfolio | josecustom.ai</title>
    <meta name="description" content="AI-Ready websites built for Orlando businesses by josecustom.ai" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;500;600;700;800;900&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <style>
      * { margin: 0; padding: 0; box-sizing: border-box; }
      html { scroll-behavior: smooth; }
      body {
        font-family: 'Inter', sans-serif;
        background: #0a0a0a;
        color: #fff;
        -webkit-font-smoothing: antialiased;
        overflow-x: hidden;
      }
      a { color: inherit; text-decoration: none; }

      .header {
        max-width: 1200px;
        margin: 0 auto;
        padding: 3rem 2rem 1rem;
      }
      .header-back {
        color: #1E90FF;
        font-size: 0.85rem;
        font-weight: 500;
        display: inline-block;
        margin-bottom: 2rem;
        transition: opacity 0.2s;
      }
      .header-back:hover { opacity: 0.7; }
      .header h1 {
        font-family: 'Orbitron', sans-serif;
        font-size: clamp(2.5rem, 6vw, 4rem);
        font-weight: 800;
        letter-spacing: -0.02em;
        margin-bottom: 1rem;
        background: linear-gradient(135deg, #fff 0%, #1E90FF 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
      }
      .header p {
        color: rgba(255,255,255,0.5);
        font-size: 1.05rem;
        max-width: 550px;
        line-height: 1.6;
      }
      .header-stats {
        display: flex;
        gap: 3rem;
        margin-top: 2rem;
      }
      .stat {
        text-align: left;
      }
      .stat-number {
        font-family: 'Orbitron', sans-serif;
        font-size: 2rem;
        font-weight: 700;
        color: #1E90FF;
      }
      .stat-label {
        font-size: 0.7rem;
        color: rgba(255,255,255,0.35);
        text-transform: uppercase;
        letter-spacing: 0.1em;
        margin-top: 0.25rem;
      }

      .scroll-hint {
        text-align: center;
        padding: 1rem 2rem 0;
        color: rgba(255,255,255,0.25);
        font-size: 0.75rem;
        letter-spacing: 0.1em;
        text-transform: uppercase;
      }
      @keyframes bounce-down {
        0%, 100% { transform: translateY(0); }
        50% { transform: translateY(6px); }
      }
      .scroll-arrow {
        display: inline-block;
        margin-top: 0.5rem;
        animation: bounce-down 1.5s ease-in-out infinite;
        font-size: 1.2rem;
      }

      .footer {
        max-width: 1200px;
        margin: 0 auto;
        padding: 4rem 2rem 3rem;
        border-top: 1px solid rgba(255,255,255,0.06);
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 1.5rem;
      }
      .footer-cta {
        font-family: 'Orbitron', sans-serif;
        font-size: 0.85rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.05em;
      }
      .footer-cta a {
        color: #1E90FF;
        transition: opacity 0.2s;
      }
      .footer-cta a:hover { opacity: 0.7; }
      .footer-copy {
        font-size: 0.65rem;
        color: rgba(255,255,255,0.2);
      }

      @media (max-width: 768px) {
        .header-stats { gap: 2rem; }
        .stat-number { font-size: 1.5rem; }
      }
    </style>
  </head>
  <body>
    <header class="header">
      <a href="https://josecustom.ai" class="header-back">&larr; josecustom.ai</a>
      <h1>Portfolio</h1>
      <p>AI-Ready websites built for Orlando businesses. Each site includes custom AI integration architecture.</p>
      <div class="header-stats">
        <div class="stat">
          <div class="stat-number">13</div>
          <div class="stat-label">Demo Sites</div>
        </div>
        <div class="stat">
          <div class="stat-number">10</div>
          <div class="stat-label">Completed</div>
        </div>
        <div class="stat">
          <div class="stat-number">$4.5k</div>
          <div class="stat-label">Starting At</div>
        </div>
      </div>
    </header>

    <div class="scroll-hint">
      Scroll to explore
      <div class="scroll-arrow">&darr;</div>
    </div>

    <PortfolioGallery client:load />

    <footer class="footer">
      <div class="footer-cta">Want a site like these? <a href="https://josecustom.ai/websites">Get started</a></div>
      <div class="footer-copy">&copy; 2026 josecustom.ai</div>
    </footer>
  </body>
</html>
