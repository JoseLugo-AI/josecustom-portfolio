---
import { PortfolioGallery } from '../components/PortfolioGallery.tsx';
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Portfolio | josecustom.ai</title>
    <meta name="description" content="AI-Ready websites built for Orlando businesses by josecustom.ai" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;500;600;700;800;900&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <style>
      * { margin: 0; padding: 0; box-sizing: border-box; }
      html { scroll-behavior: auto; overscroll-behavior: none; -webkit-overflow-scrolling: touch; }
      body {
        font-family: 'Inter', sans-serif;
        background: #0a0a0a;
        color: #fff;
        -webkit-font-smoothing: antialiased;
        overscroll-behavior: none;
      }
      a { color: inherit; text-decoration: none; }

      @keyframes bounce-down {
        0%, 100% { transform: translateY(0); }
        50% { transform: translateY(6px); }
      }

      .footer {
        max-width: 1200px;
        margin: 0 auto;
        padding: 4rem 2rem 3rem;
        border-top: 1px solid rgba(255,255,255,0.06);
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 1.5rem;
      }
      .footer-cta {
        font-family: 'Orbitron', sans-serif;
        font-size: 0.85rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.05em;
      }
      .footer-cta a {
        color: #1E90FF;
        transition: opacity 0.2s;
      }
      .footer-cta a:hover { opacity: 0.7; }
      .footer-copy {
        font-size: 0.65rem;
        color: rgba(255,255,255,0.2);
      }

      @media (max-width: 768px) {
        .footer { padding: 2rem 1.5rem; }
        .footer-cta { font-size: 0.7rem; }
      }
    </style>
  </head>
  <body>
    <PortfolioGallery client:load />

    <footer class="footer">
      <div class="footer-cta">Want a site like these? <a href="https://josecustom.ai/websites">Get started</a></div>
      <div class="footer-copy">&copy; 2026 josecustom.ai</div>
    </footer>
  </body>
</html>
